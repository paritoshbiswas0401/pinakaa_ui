<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Secure Authentication | PINAKAA Studio</title>
<link rel="icon" type="image/png" href="/assets/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
<link rel="shortcut icon" href="/assets/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="PINAKAA" />
<link rel="manifest" href="/assets/site.webmanifest" />
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

<link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-background text-on-background font-body-md antialiased min-h-screen flex flex-col pt-[80px]">
<nav class="bg-surface-container-lowest dark:bg-inverse-surface shadow-sm dark:shadow-none fixed top-0 left-0 w-full z-50 flex items-center justify-between px-margin-md h-20 mx-auto">
<div class="flex items-center gap-margin-md">
<a href="/" class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/pinakaa_logo.jpg" alt="Pinakaa Logo" class="h-14 w-auto object-contain"/>
</a>
<div class="hidden md:flex items-center gap-margin-sm h-full">
<% if (role === 'admin') { %>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/download">Containers</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/documentation">Documentation</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/contact">Contact</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/admin">Support</a>
<% } else { %>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/download">Containers</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/documentation">Documentation</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/contact">Contact</a>
<% } %>
</div>
</div>
<div class="flex items-center gap-margin-sm">
<div class="flex items-center gap-3">
<button class="text-on-surface-variant hover:text-primary transition-colors mr-2" title="<%= username ? username : 'Guest' %>">
<span class="material-symbols-outlined">account_circle</span>
</button>
<div class="flex items-center gap-margin-md">
<a class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/nsm_logo.png" alt="NSM Logo" class="h-14 w-auto object-contain" style="height: 70px;"/>
</a>
</div>
<div class="flex items-center gap-margin-md">
<a class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/cdac_logo_blue.png" alt="C-DAC Logo" class="h-14 w-auto object-contain"/>
</a>
</div>
</div>
</div>
</nav>
<!-- Main Canvas Content -->
<main class="flex-grow flex items-center justify-center p-margin-md">
<!-- Authentication Container -->
<div class="w-full max-w-md">
<!-- Branding Header (Minimalist) -->
<a href="/" class="text-center mb-margin-md block hover:opacity-80 transition-opacity" style="text-decoration: none;">
<img src="/assets/pinakaa_logo.jpg" alt="Pinakaa Stack" class="mx-auto h-24 w-auto object-contain mb-4"/>
<p class="font-body-md text-body-md text-on-surface-variant">PINAKAA Studio Access Portal</p>
</a>
<!-- Login Card -->
<div class="bg-surface-container-lowest border border-outline-variant shadow-sm rounded-lg p-margin-md relative overflow-hidden">
<!-- Top Decorative Line -->
<div class="absolute top-0 left-0 w-full h-1 bg-primary"></div>
<div class="mb-margin-sm border-b border-surface-container-highest pb-base flex items-center justify-between">
<h2 class="font-headline-md text-headline-md text-on-surface">Authentication</h2>
<div class="bg-surface-container-low px-2 py-1 rounded border border-outline-variant flex items-center gap-1">
<span class="material-symbols-outlined text-secondary text-[14px]">shield_locked</span>
<span class="font-technical-sm text-technical-sm text-secondary uppercase">TLS 1.3 Active</span>
</div>
</div>
<form action="/login" class="space-y-margin-sm" method="POST">
    <% if (error) { %>
        <div class="bg-error-container text-on-error-container p-2 rounded text-sm"><%= error %></div>
    <% } %>
<!-- Username Field -->
<div>
<label class="block font-label-caps text-label-caps text-on-surface-variant mb-2" for="username">Enterprise ID / Username / Email</label>
<div class="relative">
<div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
<span class="material-symbols-outlined text-outline">account_circle</span>
</div>
<input class="w-full pl-10 pr-3 py-2 bg-surface border border-outline-variant rounded focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary font-technical-md text-technical-md text-on-surface" id="username" name="username" placeholder="hpc_user_01 or user@example.com" required="" type="text"/>
</div>
</div>
<!-- Password Field -->
<div>
<div class="flex items-center justify-between mb-2">
<label class="block font-label-caps text-label-caps text-on-surface-variant" for="password">Passphrase</label>
<a class="font-technical-sm text-technical-sm text-primary hover:underline" href="#">Reset Auth Key?</a>
</div>
<div class="relative">
<div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
<span class="material-symbols-outlined text-outline">key</span>
</div>
<input class="w-full pl-10 pr-12 py-2 bg-surface border border-outline-variant rounded focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary font-technical-md text-technical-md text-on-surface" id="password" name="password" placeholder="••••••••••••" autocomplete="current-password" required="" type="password"/>
<button id="togglePassword" type="button" class="absolute inset-y-0 right-0 pr-3 flex items-center text-on-surface-variant hover:text-primary transition-colors" aria-label="Toggle password visibility">
<span class="material-symbols-outlined">visibility</span>
</button>
</div>
</div>
<!-- Captcha Challenge -->
<div class="bg-surface-container-low border border-outline-variant rounded p-3">
<label class="block font-label-caps text-label-caps text-on-surface-variant mb-2">Visual Verification</label>
<div class="grid gap-4 sm:grid-cols-[1fr_auto] items-center">
<div class="rounded-lg border border-outline-variant bg-white p-3 overflow-hidden" id="captchaImage">
    <%- captcha %>
</div>
<div class="flex items-center gap-2">
    <button class="inline-flex items-center justify-center rounded border border-outline-variant bg-surface px-3 py-2 text-sm font-semibold text-on-surface hover:border-primary hover:text-primary transition-colors" type="button" id="reloadCaptcha" title="Reload captcha">
        <span class="material-symbols-outlined">refresh</span>
        Refresh
    </button>
</div>
<div class="sm:col-span-2">
    <input class="w-full px-3 py-2 bg-surface border border-outline-variant rounded focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary font-technical-md text-technical-md text-on-surface" id="captcha" name="captcha" placeholder="Enter code" required="" type="text"/>
</div>
</div>
</div>
<!-- Actions -->
<div class="pt-base">
<button class="w-full bg-primary text-on-primary font-headline-md text-headline-md text-base py-3 px-4 rounded shadow-sm hover:bg-primary-container transition-colors duration-200 flex items-center justify-center gap-2" type="submit">
<span class="material-symbols-outlined">login</span>
                            Authenticate Session
                        </button>
</div>
</form>
</div>
<!-- Help Links -->
<div class="mt-base text-center">
<p class="font-technical-sm text-technical-sm text-on-surface-variant">Require assistance or access? Visit our <a class="text-primary hover:underline" href="/contact">Contact page</a> for details on how to reach us.</p>
</div>
</div>
</main>
<script>
window.addEventListener('DOMContentLoaded', () => {
    const passwordInput = document.getElementById('password');
    const togglePassword = document.getElementById('togglePassword');
    const loginForm = document.querySelector('form[action="/login"]');

    togglePassword?.addEventListener('click', () => {
        if (!passwordInput) return;
        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';
        togglePassword.innerHTML = `<span class="material-symbols-outlined">${isPassword ? 'visibility_off' : 'visibility'}</span>`;
    });

    loginForm?.addEventListener('submit', (event) => {
        const username = document.getElementById('username')?.value.trim();
        const password = passwordInput?.value.trim();
        const captcha = document.getElementById('captcha')?.value.trim();

        if (!username || !password || !captcha) {
            event.preventDefault();
            alert('Please enter your username, password, and captcha code.');
            return;
        }

        // Do not modify user input casing here; server compares case-insensitively.
    });

    document.getElementById('reloadCaptcha')?.addEventListener('click', async () => {
        const btn = document.getElementById('reloadCaptcha');
        if (btn) btn.disabled = true;
        try {
            const resp = await fetch('/captcha', { cache: 'no-store' });
            if (!resp.ok) throw new Error('Network response was not ok');
            const html = await resp.text();
            const container = document.getElementById('captchaImage');
            if (container) container.innerHTML = html;
            const input = document.getElementById('captcha');
            if (input) input.focus();
        } catch (err) {
            console.error('Failed to reload captcha', err);
            alert('Unable to reload captcha. Please try again.');
        } finally {
            if (btn) btn.disabled = false;
        }
    });
});
</script>
</main>
<!-- Footer -->
<footer class="w-full bg-surface-container-low border-t border-outline-variant py-margin-md px-margin-md flex flex-col md:flex-row justify-between items-center gap-base mx-auto">
<div class="font-headline-sm text-headline-sm font-semibold text-on-surface">
            PINAKAA Studio
        </div>
<div class="font-body-sm text-body-sm text-secondary text-center md:text-left">
            © 2026 System Software Development Group, HPC-STU, C-DAC, Bengaluru. All rights reserved.
        </div>
<nav class="flex flex-wrap justify-center gap-4">
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Terms of Service</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Privacy Policy</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Security Audit</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">API Reference</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Status</a>
</nav>
</footer>
</body></html>