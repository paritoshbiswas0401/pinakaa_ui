<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Secure Authentication | Singularity Hub</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary-fixed": "#FFF6EE",
                        "on-error-container": "#93000a",
                        "inverse-surface": "#2d3133",
                        "on-secondary-fixed-variant": "#3f465c",
                        "surface": "#ffffff",
                        "primary": "#E84E1B",
                        "on-error": "#ffffff",
                        "surface-container-highest": "#f4ede8",
                        "surface-tint": "#E84E1B",
                        "on-primary-fixed": "#4b1b00",
                        "on-background": "#191c1e",
                        "on-tertiary-fixed-variant": "#38485d",
                        "secondary-container": "#FFF1E0",
                        "inverse-primary": "#FFD6B3",
                        "on-secondary": "#ffffff",
                        "tertiary-fixed-dim": "#F7DDBA",
                        "error": "#ba1a1a",
                        "surface-container-high": "#f7efe8",
                        "primary-container": "#FFB67A",
                        "surface-bright": "#ffffff",
                        "on-primary-fixed-variant": "#9a3000",
                        "outline": "#c9a78f",
                        "surface-container": "#fff9f6",
                        "surface-container-low": "#fffaf7",
                        "surface-container-lowest": "#ffffff",
                        "inverse-on-surface": "#eff1f3",
                        "on-tertiary-container": "#FFF7E6",
                        "on-tertiary-fixed": "#0b1c30",
                        "secondary": "#6B4226",
                        "on-primary-container": "#4b1b00",
                        "surface-dim": "#f1e7df",
                        "surface-variant": "#f4ebe3",
                        "on-tertiary": "#ffffff",
                        "tertiary-fixed": "#FFD9AE",
                        "on-surface": "#191c1e",
                        "primary-fixed-dim": "#FFD6B3",
                        "on-secondary-container": "#4a3a2f",
                        "tertiary-container": "#7a5a45",
                        "error-container": "#ffdad6",
                        "background": "#fffaf7",
                        "on-primary": "#ffffff",
                        "secondary-fixed": "#FFF1E0",
                        "secondary-fixed-dim": "#F0E0CF",
                        "on-secondary-fixed": "#131b2e",
                        "outline-variant": "#e6d3c4",
                        "tertiary": "#7a5a45",
                        "on-surface-variant": "#434656"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "base": "8px",
                        "container-max": "1200px",
                        "margin-sm": "16px",
                        "margin-md": "32px",
                        "margin-lg": "64px",
                        "gutter": "24px"
                    },
                    "fontFamily": {
                        "headline-md": ["Inter"],
                        "body-lg": ["Inter"],
                        "label-caps": ["Inter"],
                        "headline-xl": ["Inter"],
                        "headline-lg": ["Inter"],
                        "body-md": ["Inter"],
                        "technical-md": ["JetBrains Mono"],
                        "body-sm": ["Inter"],
                        "technical-sm": ["JetBrains Mono"]
                    },
                    "fontSize": {
                        "headline-md": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                        "body-lg": ["18px", { "lineHeight": "28px", "fontWeight": "400" }],
                        "label-caps": ["12px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "700" }],
                        "headline-xl": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "headline-lg": ["32px", { "lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                        "body-md": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "technical-md": ["14px", { "lineHeight": "20px", "fontWeight": "500" }],
                        "body-sm": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "technical-sm": ["12px", { "lineHeight": "16px", "fontWeight": "400" }]
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-background min-h-screen flex flex-col font-body-md text-on-background">
<!-- Main Canvas Content -->
<main class="flex-grow flex items-center justify-center p-margin-md">
<!-- Authentication Container -->
<div class="w-full max-w-md">
<!-- Branding Header (Minimalist) -->
<a href="/" class="text-center mb-margin-md block hover:opacity-80 transition-opacity" style="text-decoration: none;">
<img src="/assets/Pinakaa_stack.jpeg" alt="Pinakaa Stack" class="mx-auto h-24 w-auto object-contain mb-4"/>
<p class="font-body-md text-body-md text-on-surface-variant">Secure Container Access Portal</p>
</a>
<!-- Login Card -->
<div class="bg-surface-container-lowest border border-outline-variant shadow-sm rounded-lg p-margin-md relative overflow-hidden">
<!-- Top Decorative Line -->
<div class="absolute top-0 left-0 w-full h-1 bg-primary"></div>
<div class="mb-margin-sm border-b border-surface-container-highest pb-base flex items-center justify-between">
<h2 class="font-headline-md text-headline-md text-on-surface">Authentication</h2>
<div class="bg-surface-container-low px-2 py-1 rounded border border-outline-variant flex items-center gap-1">
<span class="material-symbols-outlined text-secondary text-[14px]">shield_locked</span>
<span class="font-technical-sm text-technical-sm text-secondary uppercase">TLS 1.3 Active</span>
</div>
</div>
<form action="/login" class="space-y-margin-sm" method="POST">
    <% if (error) { %>
        <div class="bg-error-container text-on-error-container p-2 rounded text-sm"><%= error %></div>
    <% } %>
<!-- Username Field -->
<div>
<label class="block font-label-caps text-label-caps text-on-surface-variant mb-2" for="username">Enterprise ID / Username / Email</label>
<div class="relative">
<div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
<span class="material-symbols-outlined text-outline">account_circle</span>
</div>
<input class="w-full pl-10 pr-3 py-2 bg-surface border border-outline-variant rounded focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary font-technical-md text-technical-md text-on-surface" id="username" name="username" placeholder="hpc_user_01 or user@example.com" required="" type="text"/>
</div>
</div>
<!-- Password Field -->
<div>
<div class="flex items-center justify-between mb-2">
<label class="block font-label-caps text-label-caps text-on-surface-variant" for="password">Passphrase</label>
<a class="font-technical-sm text-technical-sm text-primary hover:underline" href="#">Reset Auth Key?</a>
</div>
<div class="relative">
<div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
<span class="material-symbols-outlined text-outline">key</span>
</div>
<input class="w-full pl-10 pr-12 py-2 bg-surface border border-outline-variant rounded focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary font-technical-md text-technical-md text-on-surface" id="password" name="password" placeholder="••••••••••••" autocomplete="current-password" required="" type="password"/>
<button id="togglePassword" type="button" class="absolute inset-y-0 right-0 pr-3 flex items-center text-on-surface-variant hover:text-primary transition-colors" aria-label="Toggle password visibility">
<span class="material-symbols-outlined">visibility</span>
</button>
</div>
</div>
<!-- Captcha Challenge (Simulated Visual Challenge) -->
<div class="bg-surface-container-low border border-outline-variant rounded p-3">
<label class="block font-label-caps text-label-caps text-on-surface-variant mb-2">Visual Verification</label>
<div class="flex items-center gap-base">
<div class="flex-shrink-0 w-24 h-12 bg-surface border border-outline-variant rounded flex items-center justify-center relative overflow-hidden">
<!-- Simulated Captcha Image -->
<img alt="Security visual verification challenge" class="absolute inset-0 w-full h-full object-cover opacity-80 mix-blend-luminosity" data-alt="A macro photograph of complex, glowing fiber optic cables transmitting blue and white light. The image represents digital security and data transfer in a high-tech environment. The lighting is crisp and cool, emphasizing the intricate details of the glass fibers against a dark background, fitting a secure corporate aesthetic." src="https://lh3.googleusercontent.com/aida-public/AB6AXuD_qyZrw1uyLi8aHqru5ijZ3soUckUB_zhGOJ3Q0QdqFwRdC5T3HL6iSumzqTb-kAm1sBtXYoLrSWYLY0KG0yZY2FlerMAGHH9l-2-DbeZOeJlLhNzV_DK1bg-sAzLI-jweDvRtLzlxaGvUW8HYXHfRIkp0ijqsHrOIcfsUGu22ag9kwlOUx9ko5FRvA8rk8f2HfQOZ2HH_R1kS6WKrrOzKpQJ1VgAOUNUWqIocFjTNHQywVvIaQA9cc2off34VgDHpMiIPyLI2NvQ"/>
<span class="font-technical-md text-technical-md font-bold text-on-surface z-10 bg-surface/50 px-1 backdrop-blur-sm">8F2A</span>
</div>
<div class="flex-grow">
<div class="relative">
<input class="w-full px-3 py-2 bg-surface border border-outline-variant rounded focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary font-technical-md text-technical-md text-on-surface uppercase" id="captcha" name="captcha" placeholder="Enter Code" required="" type="text"/>
</div>
</div>
<button class="p-2 text-secondary hover:text-primary transition-colors" title="Reload Challenge" type="button">
<span class="material-symbols-outlined">refresh</span>
</button>
</div>
</div>
<!-- Actions -->
<div class="pt-base">
<button class="w-full bg-primary text-on-primary font-headline-md text-headline-md text-base py-3 px-4 rounded shadow-sm hover:bg-primary-container transition-colors duration-200 flex items-center justify-center gap-2" type="submit">
<span class="material-symbols-outlined">login</span>
                            Authenticate Session
                        </button>
</div>
</form>
</div>
<!-- Help Links -->
<div class="mt-base text-center">
<p class="font-technical-sm text-technical-sm text-on-surface-variant">Require assistance or access? Visit our <a class="text-primary hover:underline" href="/contact">Contact page</a> for details on how to reach us.</p>
</div>
</div>
</main>
<script>
window.addEventListener('DOMContentLoaded', () => {
    const passwordInput = document.getElementById('password');
    const togglePassword = document.getElementById('togglePassword');
    const loginForm = document.querySelector('form[action="/login"]');

    togglePassword?.addEventListener('click', () => {
        if (!passwordInput) return;
        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';
        togglePassword.innerHTML = `<span class="material-symbols-outlined">${isPassword ? 'visibility_off' : 'visibility'}</span>`;
    });

    loginForm?.addEventListener('submit', (event) => {
        const username = document.getElementById('username')?.value.trim();
        const password = passwordInput?.value.trim();
        const captcha = document.getElementById('captcha')?.value.trim();

        if (!username || !password || !captcha) {
            event.preventDefault();
            alert('Please enter your username, password, and captcha code.');
            return;
        }

        if (document.getElementById('captcha')) {
            document.getElementById('captcha').value = captcha.toUpperCase();
        }
    });
});
</script>
</main>
<!-- Footer -->
<footer class="w-full bg-surface-container-low border-t border-outline-variant py-margin-md px-margin-md flex flex-col md:flex-row justify-between items-center gap-base max-w-container-max mx-auto">
<div class="font-headline-sm text-headline-sm font-semibold text-on-surface">
            Singularity Hub
        </div>
<div class="font-body-sm text-body-sm text-secondary text-center md:text-left">
            © 2024 HPC Systems. All rights reserved. Secure Singularity Container Distribution.
        </div>
<nav class="flex flex-wrap justify-center gap-4">
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Terms of Service</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Privacy Policy</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Security Audit</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">API Reference</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Status</a>
</nav>
</footer>
</body></html>