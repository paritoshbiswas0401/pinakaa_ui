<body class="bg-background text-on-background font-body-md antialiased min-h-screen flex flex-col pt-[80px]">
<!-- TopNavBar Component -->
<nav class="bg-surface-container-lowest dark:bg-inverse-surface shadow-sm dark:shadow-none fixed top-0 left-0 w-full z-50 flex items-center justify-between px-margin-md h-20 mx-auto">
<div class="flex items-center gap-margin-md">
<a href="/" class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/pinakaa_logo.jpg" alt="Pinakaa Logo" class="h-14 w-auto object-contain"/>
</a>
<div class="hidden md:flex items-center gap-margin-sm h-full">
<% if (role === 'admin') { %>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/download">Containers</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/documentation">Documentation</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/contact">Request for login</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/admin">Support</a>
<% } else { %>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/download">Containers</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/documentation">Documentation</a>
<a class="text-body-md text-primary dark:text-inverse-primary border-b-2 border-primary dark:border-inverse-primary font-bold pb-1 h-full flex items-center" href="/contact">Request for login</a>
<% } %>
</div>
</div>
<div class="flex items-center gap-margin-sm">
<!-- Search Bar placeholder for "on_right" -->
<div class="hidden lg:flex items-center bg-surface-container border border-outline-variant rounded px-3 py-1.5 focus-within:border-primary transition-colors">
<span class="material-symbols-outlined text-on-surface-variant mr-2" style="font-size: 18px;">search</span>
<input class="bg-transparent border-none focus:ring-0 text-body-sm font-body-sm p-0 w-48 placeholder-on-surface-variant" placeholder="Search..." type="text"/>
</div>
<div class="flex items-center gap-3">
<button class="text-on-surface-variant hover:text-primary transition-colors mr-2" title="<%= username ? username : 'Guest' %>">
<span class="material-symbols-outlined">account_circle</span>
</button>
<% if (username) { %>
<a class="bg-white text-primary border border-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container hover:text-on-primary transition-colors ml-2 hidden sm:block" href="/change-password" style="text-decoration: none;">
                    Change Password
                </a>
<a class="bg-primary text-on-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container transition-colors ml-2 hidden sm:block" href="/logout" style="text-decoration: none;">
                    Logout
                </a>
<% } else { %>
<a class="bg-primary text-on-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container transition-colors ml-2 hidden sm:block" href="/login" style="text-decoration: none;">
                    Login
                </a>
<% } %>

<div class="flex items-center gap-margin-md">
<a class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/nsm_logo.png" alt="NSM Logo" class="h-14 w-auto object-contain" style="height: 70px;"/>
</a>
</div>
<div class="flex items-center gap-margin-md">
<a class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/cdac_logo_blue.png" alt="C-DAC Logo" class="h-14 w-auto object-contain"/>
</a>
</div>

</div>
</div>
</nav>
<!-- Main Content -->
<main class="flex-grow w-full max-w-container-max mx-auto px-4 md:px-margin-md py-margin-md">
<!-- Status Header -->
<div class="mb-margin-md flex items-center justify-between">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-blue-600 bg-blue-100 p-2 rounded-full" style="font-variation-settings: 'FILL' 1;">contact_support</span>
<div>
<h1 class="font-headline-lg text-headline-lg text-on-background">Request for Login</h1>
<p class="font-body-sm text-body-sm text-on-surface-variant">Submit your login access request here and our team will review it within 24 hours.</p>
</div>
</div>
</div>
<!-- Contact Sections -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter">
<!-- General Queries -->
<div class="bg-surface-container-lowest border border-surface-variant rounded-lg p-margin-md shadow-[0_4px_20px_rgba(15,23,42,0.05)]">
<div class="flex items-start gap-4">
<span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">help_center</span>
<div class="flex-1">
<h2 class="font-headline-md text-headline-md text-on-surface mb-2">General Queries</h2>
<p class="font-body-md text-body-md text-on-surface-variant mb-4">For any general questions, support requests, or technical assistance, please write to us at:</p>
<a href="mailto:pinakaa@cdac.in" class="inline-flex items-center gap-2 bg-primary text-on-primary px-4 py-2 rounded font-technical-md hover:bg-primary-container transition-colors">
<span class="material-symbols-outlined" style="font-size: 18px;">email</span>
pinakaa@cdac.in
</a>
</div>
</div>
</div>
<!-- Access Requests -->
<div class="bg-surface-container-lowest border border-surface-variant rounded-lg p-margin-md shadow-[0_4px_20px_rgba(15,23,42,0.05)]">
<div class="flex items-start gap-4">
<span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">person_add</span>
<div class="flex-1">
<h2 class="font-headline-md text-headline-md text-on-surface mb-2">Request for Login</h2>
<p class="font-body-md text-body-md text-on-surface-variant mb-4">Complete the form below and we'll process your login request as quickly as possible.</p>
<% if (error) { %>
<div class="rounded-lg border border-error-container bg-error-container px-4 py-3 mb-4 text-on-error-container">
<p class="font-body-sm font-semibold">There was an issue submitting your request:</p>
<p class="font-body-sm"><%= error %></p>
</div>
<% } %>
<form method="POST" action="/contact" class="space-y-4">
<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
<div>
<label class="block text-body-sm text-on-surface mb-1" for="name">Name</label>
<input id="name" name="name" type="text" required value="<%= formData.name || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" />
</div>
<div>
<label class="block text-body-sm text-on-surface mb-1" for="email">Email</label>
<input id="email" name="email" type="email" required value="<%= formData.email || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" />
</div>
<div>
<label class="block text-body-sm text-on-surface mb-1" for="role">Roles</label>
<select id="role" name="role" required class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none">
<option value="" disabled <%= !formData.role ? 'selected' : '' %>>Select a role</option>
<option value="Deployment team" <%= formData.role === 'Deployment team' ? 'selected' : '' %>>Deployment team</option>
<option value="Product Owner" <%= formData.role === 'Product Owner' ? 'selected' : '' %>>Product Owner</option>
<option value="CI/CD Executor" <%= formData.role === 'CI/CD Executor' ? 'selected' : '' %>>CI/CD Executor</option>
<option value="CI/CD Admin" <%= formData.role === 'CI/CD Admin' ? 'selected' : '' %>>CI/CD Admin</option>
<option value="TCG" <%= formData.role === 'TCG' ? 'selected' : '' %>>TCG</option>
</select>
</div>
<div id="productOwnerFields" class="space-y-4 <%= formData.role === 'Product Owner' ? '' : 'hidden' %>">
    <div>
        <label class="block text-body-sm text-on-surface mb-1" for="product_name">Product name</label>
        <input id="product_name" name="product_name" type="text" value="<%= formData.productName || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" placeholder="Product name" />
    </div>
    <div>
        <label class="block text-body-sm text-on-surface mb-1" for="team_name">Team name</label>
        <input id="team_name" name="team_name" type="text" value="<%= formData.teamName || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" placeholder="Team name" />
    </div>
</div>
<div id="deploymentTeamAccess" class="space-y-4 <%= formData.role === 'Deployment team' ? '' : 'hidden' %>">
    <div>
        <label class="block text-body-sm text-on-surface mb-1">Container access type</label>
        <div class="relative">
            <button type="button" id="containerAccessToggle" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-left text-body-sm text-on-surface flex items-center justify-between focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary">
                <span id="containerAccessSummary" class="truncate"><%= Array.isArray(formData.containerAccess) ? formData.containerAccess.join(', ') : formData.containerAccess || 'Select one or more options' %></span>
                <span class="material-symbols-outlined">expand_more</span>
            </button>
            <div id="containerAccessList" class="absolute left-0 right-0 mt-1 max-h-56 overflow-auto rounded border border-outline-variant bg-surface p-3 shadow-lg hidden">
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="GPU-Optimized" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('GPU-Optimized') : formData.containerAccess === 'GPU-Optimized') ? 'checked' : '' %> class="h-4 w-4" /> <span>GPU-Optimized</span></label>
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="CPU-Only" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('CPU-Only') : formData.containerAccess === 'CPU-Only') ? 'checked' : '' %> class="h-4 w-4" /> <span>CPU-Only</span></label>
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="AMD Based" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('AMD Based') : formData.containerAccess === 'AMD Based') ? 'checked' : '' %> class="h-4 w-4" /> <span>AMD Based</span></label>
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="Intel Based" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('Intel Based') : formData.containerAccess === 'Intel Based') ? 'checked' : '' %> class="h-4 w-4" /> <span>Intel Based</span></label>
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="RISC-V Based" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('RISC-V Based') : formData.containerAccess === 'RISC-V Based') ? 'checked' : '' %> class="h-4 w-4" /> <span>RISC-V Based</span></label>
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="For Cluster" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('For Cluster') : formData.containerAccess === 'For Cluster') ? 'checked' : '' %> class="h-4 w-4" /> <span>For Cluster</span></label>
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="For Single Server" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('For Single Server') : formData.containerAccess === 'For Single Server') ? 'checked' : '' %> class="h-4 w-4" /> <span>For Single Server</span></label>
            </div>
            <p id="containerAccessError" class="mt-2 text-sm text-red-700 hidden">Select at least one access type.</p>
        </div>
    </div>
</div>
<div>
<label class="block text-body-sm text-on-surface mb-1" for="target-device">Target Device/Architecture</label>
<input id="target-device" name="target-device" type="text" required value="<%= formData.targetDevice || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" placeholder="e.g., x86_64, ARM64" />
</div>
</div>
<div>
<label class="block text-body-sm text-on-surface mb-1" for="purpose">Purpose</label>
<textarea id="purpose" name="purpose" required rows="4" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" placeholder="Describe your intended use"><%= formData.purpose || '' %></textarea>
</div>
<div>
<label class="block text-body-sm text-on-surface mb-1" for="organization">Organization/Centre</label>
<input id="organization" name="organization" type="text" required value="<%= formData.organization || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" />
</div>
<button type="submit" class="inline-flex items-center justify-center rounded bg-primary px-6 py-3 text-on-primary font-semibold hover:bg-primary-container transition-colors">Submit Request</button>
</form>
</div>
</div>
</div>
</main>
<footer class="w-full bg-surface-container-low border-t border-outline-variant mt-auto">
<div class="w-full py-margin-md px-margin-md flex flex-col md:flex-row justify-between items-center gap-base mx-auto">
<div class="flex flex-col gap-2 items-center md:items-start text-center md:text-left">
<!-- Fallback to JSON standard structure for Brand Logo if needed, though mostly standard copyright -->
<p class="font-body-sm text-body-sm text-secondary">© 2026 System Software Development Group, NSM-STF, C-DAC, Bengaluru. All rights reserved</p>
</div>
<nav class="flex flex-wrap justify-center gap-margin-sm">
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Terms of Service</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Privacy Policy</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Security Audit</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">API Reference</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Status</a>
</nav>
</div>
</footer>
<script>
const roleSelect = document.getElementById('role');
const productOwnerFields = document.getElementById('productOwnerFields');
const deploymentTeamAccess = document.getElementById('deploymentTeamAccess');

function updateRoleFields() {
    const role = roleSelect.value;
    const isProductOwner = role === 'Product Owner';
    const isDeploymentTeam = role === 'Deployment team';

    productOwnerFields.classList.toggle('hidden', !isProductOwner);
    deploymentTeamAccess.classList.toggle('hidden', !isDeploymentTeam);

    document.getElementById('product_name').required = isProductOwner;
    document.getElementById('team_name').required = isProductOwner;
}

function updateContainerAccessSummary() {
    const summary = document.getElementById('containerAccessSummary');
    const checkboxes = [...document.querySelectorAll('#containerAccessList input[name="container-access"]')];
    const selected = checkboxes.filter(cb => cb.checked).map(cb => cb.value);
    summary.textContent = selected.length ? selected.join(', ') : 'Select one or more options';
}

function validateContainerAccess() {
    const checkboxes = [...document.querySelectorAll('#containerAccessList input[name="container-access"]')];
    const error = document.getElementById('containerAccessError');
    const isDeploymentTeam = roleSelect.value === 'Deployment team';
    const selected = checkboxes.some(cb => cb.checked);

    if (!isDeploymentTeam) {
        error.classList.add('hidden');
        return true;
    }

    if (!selected) {
        error.classList.remove('hidden');
        return false;
    }

    error.classList.add('hidden');
    return true;
}

const containerAccessToggle = document.getElementById('containerAccessToggle');
const containerAccessList = document.getElementById('containerAccessList');
const containerCheckboxes = document.querySelectorAll('#containerAccessList input[name="container-access"]');

containerCheckboxes.forEach(cb => cb.addEventListener('change', () => {
    updateContainerAccessSummary();
    validateContainerAccess();
}));

if (containerAccessToggle) {
    containerAccessToggle.addEventListener('click', () => {
        containerAccessList.classList.toggle('hidden');
    });
}

const contactForm = document.querySelector('form[action="/contact"]');
if (contactForm) {
    contactForm.addEventListener('submit', (event) => {
        if (!validateContainerAccess()) {
            event.preventDefault();
            const isDeploymentTeam = roleSelect.value === 'Deployment team';
            if (isDeploymentTeam) {
                containerAccessList.classList.remove('hidden');
            }
        }
    });
}

if (roleSelect) {
    roleSelect.addEventListener('change', updateRoleFields);
    updateRoleFields();
    updateContainerAccessSummary();
}
</script>
</body>
</html>