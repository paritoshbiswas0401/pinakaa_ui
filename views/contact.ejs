<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Request for Login - PINAKAA Studio</title>
<link rel="icon" type="image/png" href="/assets/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
<link rel="shortcut icon" href="/assets/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="PINAKAA" />
<link rel="manifest" href="/assets/site.webmanifest" />
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

<link rel="stylesheet" href="/css/style.css" />
<style>
        /* Ambient shadow utility for subtle depth */
        .shadow-ambient {
            box-shadow: 0px 4px 20px rgba(15, 23, 42, 0.05);
        }
        /* Smooth animation for report section panel */
        #reportSectionPanel {
            transition: max-height 0.3s ease-in-out, opacity 0.3s ease-in-out;
            max-height: 2000px;
            opacity: 1;
        }
        #reportSectionPanel.hidden {
            max-height: 0;
            opacity: 0;
            overflow: hidden;
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md antialiased min-h-screen flex flex-col pt-[80px]">
<!-- TopNavBar Component -->
<nav class="bg-surface-container-lowest dark:bg-inverse-surface shadow-sm dark:shadow-none fixed top-0 left-0 w-full z-50 flex items-center justify-between px-margin-md h-20 mx-auto">
<div class="flex items-center gap-margin-md">
<a href="/" class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/pinakaa_logo.jpg" alt="Pinakaa Logo" class="h-14 w-auto object-contain"/>
</a>
<div class="hidden md:flex items-center gap-margin-sm h-full">
<% if (role === 'admin') { %>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/download">Containers</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/documentation">Documentation</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/contact">Request for login</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/admin">Support</a>
<% } else { %>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/download">Containers</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/documentation">Documentation</a>
<a class="text-body-md text-primary dark:text-inverse-primary border-b-2 border-primary dark:border-inverse-primary font-bold pb-1 h-full flex items-center" href="/contact">Request for login</a>
<% } %>
</div>
</div>
<div class="flex items-center gap-margin-sm">
<!-- Search Bar placeholder for "on_right" -->
<!-- <div class="hidden lg:flex items-center bg-surface-container border border-outline-variant rounded px-3 py-1.5 focus-within:border-primary transition-colors">
<span class="material-symbols-outlined text-on-surface-variant mr-2" style="font-size: 18px;">search</span>
<input class="bg-transparent border-none focus:ring-0 text-body-sm font-body-sm p-0 w-48 placeholder-on-surface-variant" placeholder="Search..." type="text"/>
</div> -->
<div class="flex items-center gap-3">
<button class="text-on-surface-variant hover:text-primary transition-colors mr-2" title="<%= username ? username : 'Guest' %>">
<span class="material-symbols-outlined">account_circle</span>
</button>
<% if (username) { %>
<a class="bg-white text-primary border border-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container hover:text-on-primary transition-colors ml-2 hidden sm:block" href="/change-password" style="text-decoration: none;">
                    Change Password
                </a>
<a class="bg-primary text-on-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container transition-colors ml-2 hidden sm:block" href="/logout" style="text-decoration: none;">
                    Logout
                </a>
<% } else { %>
<a class="bg-primary text-on-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container transition-colors ml-2 hidden sm:block" href="/login" style="text-decoration: none;">
                    Login
                </a>
<% } %>

<div class="flex items-center gap-margin-md">
<a class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/nsm_logo.png" alt="NSM Logo" class="h-14 w-auto object-contain" style="height: 70px;"/>
</a>
</div>
<div class="flex items-center gap-margin-md">
<a class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/cdac_logo_blue.png" alt="C-DAC Logo" class="h-14 w-auto object-contain"/>
</a>
</div>

</div>
</div>
</nav>
<!-- Main Content -->
<main class="flex-grow w-full max-w-container-max mx-auto px-4 md:px-margin-md py-margin-md">
<!-- Status Header -->
<div class="mb-margin-md flex items-center justify-between">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-blue-600 bg-blue-100 p-2 rounded-full" style="font-variation-settings: 'FILL' 1;">contact_support</span>
<div>
<h1 class="font-headline-lg text-headline-lg text-on-background">Request for Login</h1>
<p class="font-body-sm text-body-sm text-on-surface-variant">Submit your login access request here and our team will review it within 24 hours.</p>
</div>
</div>
</div>
<!-- Contact Sections -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter">
    <div class="space-y-6">
        <div class="bg-surface-container-lowest border border-surface-variant rounded-lg p-margin-md shadow-[0_4px_20px_rgba(15,23,42,0.05)]">
            <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">help_center</span>
                <div class="flex-1">
                    <h2 class="font-headline-md text-headline-md text-on-surface mb-2">General Queries</h2>
                    <p class="font-body-md text-body-md text-on-surface-variant mb-4">For any general questions, support requests, or technical assistance, please write to us at:</p>
                    <a href="mailto:pinakaa@cdac.in" class="inline-flex items-center gap-2 bg-primary text-on-primary px-4 py-2 rounded font-technical-md hover:bg-primary-container transition-colors">
                        <span class="material-symbols-outlined" style="font-size: 18px;">email</span>
                        pinakaa@cdac.in
                    </a>
                </div>
            </div>
        </div>

        <div class="bg-surface-container-lowest border border-surface-variant rounded-lg p-margin-md shadow-[0_4px_20px_rgba(15,23,42,0.05)]">
            <div class="flex items-start justify-between gap-4 mb-4">
                <div class="flex items-start gap-4">
                    <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">report_problem</span>
                    <div class="flex-1">
                        <h2 class="font-headline-md text-headline-md text-on-surface mb-2">Report Deployment Issues</h2>
                        <p class="font-body-md text-body-md text-on-surface-variant">Upload validation logs and share deployment issues with the PINAKAA team.</p>
                    </div>
                </div>
                <button type="button" id="reportSectionToggle" class="inline-flex items-center justify-center h-10 w-10 rounded border border-primary text-primary hover:bg-primary-container/10 transition-colors" title="Toggle report details" aria-expanded="<%= reportError || reportSuccess ? 'true' : 'false' %>">
                    <span id="reportSectionToggleIcon" class="material-symbols-outlined transition-transform duration-200 <%= reportError || reportSuccess ? 'rotate-180' : '' %>">expand_more</span>
                </button>
            </div>
            <% if (!username) { %>
                        <p class="text-body-sm text-on-surface-variant">You need to be logged in to submit a deployment issue report. <a href="/login" class="text-primary underline">Login</a></p>
            <% } %>
            <div id="reportSectionPanel" class="<%= reportError || reportSuccess ? '' : 'hidden' %> space-y-4">
                <% if (reportError) { %>
                    <div class="rounded-lg border border-error-container bg-error-container px-4 py-3 mb-4 text-on-error-container">
                        <p class="font-body-sm font-semibold">Unable to send the report:</p>
                        <p class="font-body-sm"><%= reportError %></p>
                    </div>
                <% } %>
                <% if (reportSuccess) { %>
                    <div class="rounded-lg border border-success-container bg-success-container px-4 py-3 mb-4 text-on-surface">
                        <p class="font-body-sm font-semibold">Success</p>
                        <p class="font-body-sm"><%= reportSuccess %></p>
                    </div>
                <% } %>
                <form method="POST" action="/report-status" enctype="multipart/form-data" class="space-y-4">
                    <div id="reportFilesInputs"></div>
                    <div class="rounded border border-outline-variant bg-surface-container-lowest p-4 space-y-3">
                        <div class="flex items-center justify-between gap-2">
                            <label class="block text-body-sm text-on-surface mb-1" for="reportFilesAddButton">Attach files</label>
                            <button type="button" id="reportFilesAddButton" class="inline-flex items-center justify-center rounded border border-outline-variant bg-surface px-4 py-2 text-body-sm text-on-surface hover:bg-primary-container/10 transition-colors">Add files</button>
                        </div>
                        <div id="reportFilesList" class="mt-2 grid gap-2"></div>
                        <p id="reportFilesError" class="text-body-xs text-error-container mt-2 hidden"></p>
                        <p class="text-body-xs text-on-surface-variant mt-2">Allowed formats: .png, .jpg, .jpeg, .pdf, .docx, .txt</p>
                    </div>
                    <div>
                        <label class="block text-body-sm text-on-surface mb-1" for="report_message">Validation Logs / Env Issues</label>
                        <textarea id="report_message" name="report_message" rows="4" required class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" placeholder="Describe validation logs or environment issues"><%= (reportForm && reportForm.reportMessage) || '' %></textarea>
                    </div>
                    <div>
                        <label class="block text-body-sm text-on-surface mb-1" for="server_architecture">Server name & architecture</label>
                        <input id="server_architecture" name="server_architecture" type="text" required value="<%= (reportForm && reportForm.serverArchitecture) || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" placeholder="e.g. server1.example.com / x86_64" />
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-body-sm text-on-surface mb-1" for="runtime_used">Runtime used</label>
                            <select id="runtime_used" name="runtime_used" required class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none">
                                <option value="" disabled <%= !(reportForm && reportForm.runtimeUsed) ? 'selected' : '' %>>Select runtime</option>
                                <option value="SingularityCE" <%= (reportForm && reportForm.runtimeUsed) === 'SingularityCE' ? 'selected' : '' %>>SingularityCE</option>
                                <option value="Apptainer" <%= (reportForm && reportForm.runtimeUsed) === 'Apptainer' ? 'selected' : '' %>>Apptainer</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-body-sm text-on-surface mb-1" for="runtime_version">Runtime version</label>
                            <input id="runtime_version" name="runtime_version" type="text" required value="<%= (reportForm && reportForm.runtimeVersion) || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" placeholder="Version" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-body-sm text-on-surface mb-1" for="packages_versions">Packages deployed & versions</label>
                        <textarea id="packages_versions" name="packages_versions" rows="3" required class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" placeholder="List packages and versions"><%= (reportForm && reportForm.packagesVersions) || '' %></textarea>
                    </div>
                    <button type="submit" class="inline-flex items-center justify-center rounded bg-primary px-6 py-3 text-on-primary font-semibold hover:bg-primary-container transition-colors"><%= username ? 'Submit Deployment Report' : 'Login to Submit Report' %></button>
                </form>
            </div>
        </div>
    </div>
    <div class="bg-surface-container-lowest border border-surface-variant rounded-lg p-margin-md shadow-[0_4px_20px_rgba(15,23,42,0.05)]">
        <div class="flex items-start gap-4">
<span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">person_add</span>
<div class="flex-1">
<h2 class="font-headline-md text-headline-md text-on-surface mb-2">Request for Login</h2>
<p class="font-body-md text-body-md text-on-surface-variant mb-4">Complete the form below and we'll process your login request as quickly as possible.</p>
<% if (error) { %>
<div class="rounded-lg border border-error-container bg-error-container px-4 py-3 mb-4 text-on-error-container">
<p class="font-body-sm font-semibold">There was an issue submitting your request:</p>
<p class="font-body-sm"><%= error %></p>
</div>
<% } %>
<form method="POST" action="/contact" class="space-y-4">
<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
<div>
<label class="block text-body-sm text-on-surface mb-1" for="name">Name</label>
<input id="name" name="name" type="text" autocomplete="name" required value="<%= formData.name || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" />
</div>
<div>
<label class="block text-body-sm text-on-surface mb-1" for="email">Email</label>
<input id="email" name="email" type="email" autocomplete="email" required value="<%= formData.email || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" />
</div>
<div>
<label class="block text-body-sm text-on-surface mb-1" for="role">Roles</label>
<select id="role" name="role" required class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none">
<option value="" disabled <%= !formData.role ? 'selected' : '' %>>Select a role</option>
<option value="Deployment team" <%= formData.role === 'Deployment team' ? 'selected' : '' %>>Deployment team</option>
<option value="Product Owner" <%= formData.role === 'Product Owner' ? 'selected' : '' %>>Product Owner</option>
<option value="CI/CD Executor" <%= formData.role === 'CI/CD Executor' ? 'selected' : '' %>>CI/CD Executor</option>
<option value="CI/CD Admin" <%= formData.role === 'CI/CD Admin' ? 'selected' : '' %>>CI/CD Admin</option>
<option value="TCG" <%= formData.role === 'TCG' ? 'selected' : '' %>>TCG</option>
</select>
</div>
<div id="roleSpecificFields" class="space-y-4 <%= formData.role === 'Product Owner' || formData.role === 'Deployment team' ? '' : 'hidden' %>">
    <div id="productNameField" class="<%= formData.role === 'Product Owner' ? '' : 'hidden' %>">
        <label class="block text-body-sm text-on-surface mb-1" for="product_name">Product name</label>
        <input id="product_name" name="product_name" type="text" required value="<%= formData.productName || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" placeholder="Product name" />
    </div>
    <div>
        <label class="block text-body-sm text-on-surface mb-1" for="team_name">Team name</label>
        <input id="team_name" name="team_name" type="text" required value="<%= formData.teamName || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" placeholder="Team name" />
    </div>
    <div>
        <label class="block text-body-sm text-on-surface mb-1" for="hod_contact">Name & Email of HOD</label>
        <input id="hod_contact" name="hod_contact" type="text" required value="<%= formData.hodContact || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" placeholder="e.g. John Doe john.doe@company.com" />
    </div>
</div>
<div id="deploymentTeamAccess" class="space-y-4 <%= formData.role === 'Deployment team' ? '' : 'hidden' %>">
    <div>
        <label class="block text-body-sm text-on-surface mb-1" for="containerAccessToggle">Container access type</label>
        <div class="relative">
            <button type="button" id="containerAccessToggle" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-left text-body-sm text-on-surface flex items-center justify-between focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary">
                <span id="containerAccessSummary" class="truncate"><%= Array.isArray(formData.containerAccess) ? formData.containerAccess.join(', ') : formData.containerAccess || 'Select one or more options' %></span>
                <span class="material-symbols-outlined">expand_more</span>
            </button>
            <div id="containerAccessList" class="absolute left-0 right-0 mt-1 max-h-56 overflow-auto rounded border border-outline-variant bg-surface p-3 shadow-lg hidden">
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="GPU-Optimized" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('GPU-Optimized') : formData.containerAccess === 'GPU-Optimized') ? 'checked' : '' %> class="h-4 w-4" /> <span>GPU-Optimized</span></label>
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="CPU-Only" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('CPU-Only') : formData.containerAccess === 'CPU-Only') ? 'checked' : '' %> class="h-4 w-4" /> <span>CPU-Only</span></label>
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="AMD Based" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('AMD Based') : formData.containerAccess === 'AMD Based') ? 'checked' : '' %> class="h-4 w-4" /> <span>AMD Based</span></label>
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="Intel Based" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('Intel Based') : formData.containerAccess === 'Intel Based') ? 'checked' : '' %> class="h-4 w-4" /> <span>Intel Based</span></label>
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="RISC-V Based" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('RISC-V Based') : formData.containerAccess === 'RISC-V Based') ? 'checked' : '' %> class="h-4 w-4" /> <span>RISC-V Based</span></label>
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="For Cluster" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('For Cluster') : formData.containerAccess === 'For Cluster') ? 'checked' : '' %> class="h-4 w-4" /> <span>For Cluster</span></label>
                <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="container-access" value="For Single Server" <%= (Array.isArray(formData.containerAccess) ? formData.containerAccess.includes('For Single Server') : formData.containerAccess === 'For Single Server') ? 'checked' : '' %> class="h-4 w-4" /> <span>For Single Server</span></label>
            </div>
            <p id="containerAccessError" class="mt-2 text-sm text-red-700 hidden">Select at least one access type.</p>
        </div>
    </div>
</div>
<div>
<label class="block text-body-sm text-on-surface mb-1" for="targetDeviceToggle">Target Device/Architecture</label>
<div class="relative">
    <button type="button" id="targetDeviceToggle" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-left text-body-sm text-on-surface flex items-center justify-between focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary">
        <span id="targetDeviceSummary" class="truncate"><%= Array.isArray(formData.targetDevice) ? formData.targetDevice.join(', ') : formData.targetDevice || 'Select one or more options' %></span>
        <span class="material-symbols-outlined">expand_more</span>
    </button>
    <div id="targetDeviceList" class="absolute left-0 right-0 mt-1 max-h-56 overflow-auto rounded border border-outline-variant bg-surface p-3 shadow-lg hidden">
        <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="target-device" value="x86_64" <%= (Array.isArray(formData.targetDevice) ? formData.targetDevice.includes('x86_64') : formData.targetDevice === 'x86_64') ? 'checked' : '' %> class="h-4 w-4" /> <span>x86_64</span></label>
        <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="target-device" value="AArch64" <%= (Array.isArray(formData.targetDevice) ? formData.targetDevice.includes('AArch64') : formData.targetDevice === 'AArch64') ? 'checked' : '' %> class="h-4 w-4" /> <span>AArch64</span></label>
        <label class="inline-flex items-center gap-2 mb-2 w-full"><input type="checkbox" name="target-device" value="RV64GC" <%= (Array.isArray(formData.targetDevice) ? formData.targetDevice.includes('RV64GC') : formData.targetDevice === 'RV64GC') ? 'checked' : '' %> class="h-4 w-4" /> <span>RV64GC</span></label>
    </div>
    <p id="targetDeviceError" class="mt-2 text-sm text-red-700 hidden">Select at least one target device.</p>
</div>
</div>
<div>
<label class="block text-body-sm text-on-surface mb-1" for="purpose">Purpose</label>
<textarea id="purpose" name="purpose" required rows="4" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" placeholder="Describe your intended use"><%= formData.purpose || '' %></textarea>
</div>
<div>
<label class="block text-body-sm text-on-surface mb-1" for="organization">Organization/Centre</label>
<input id="organization" name="organization" type="text" autocomplete="organization" required value="<%= formData.organization || '' %>" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-primary focus:outline-none" />
</div>
<button type="submit" class="inline-flex items-center justify-center rounded bg-primary px-6 py-3 text-on-primary font-semibold hover:bg-primary-container transition-colors">Submit Request</button>
</form>
</div>
</div>
</div>
</main>
<footer class="w-full bg-surface-container-low border-t border-outline-variant mt-auto">
<div class="w-full py-margin-md px-margin-md flex flex-col md:flex-row justify-between items-center gap-base mx-auto">
<div class="flex flex-col gap-2 items-center md:items-start text-center md:text-left">
<!-- Fallback to JSON standard structure for Brand Logo if needed, though mostly standard copyright -->
<p class="font-body-sm text-body-sm text-secondary">© 2026 System Software Development Group, HPC-STU, C-DAC, Bengaluru. All rights reserved</p>
</div>
<nav class="flex flex-wrap justify-center gap-margin-sm">
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Terms of Service</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Privacy Policy</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Security Audit</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">API Reference</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Status</a>
</nav>
</div>
</footer>
<script>
const roleSelect = document.getElementById('role');
const roleSpecificFields = document.getElementById('roleSpecificFields');
const deploymentTeamAccess = document.getElementById('deploymentTeamAccess');

function updateRoleFields() {
    const role = roleSelect.value;
    const isProductOwner = role === 'Product Owner';
    const isDeploymentTeam = role === 'Deployment team';
    const roleFieldsVisible = isProductOwner || isDeploymentTeam;

    if (roleSpecificFields) {
        roleSpecificFields.classList.toggle('hidden', !roleFieldsVisible);
    }
    if (deploymentTeamAccess) {
        deploymentTeamAccess.classList.toggle('hidden', !isDeploymentTeam);
    }

    const productNameField = document.getElementById('productNameField');
    const productNameInput = document.getElementById('product_name');
    const teamNameInput = document.getElementById('team_name');
    const hodContactInput = document.getElementById('hod_contact');

    if (productNameField) {
        productNameField.classList.toggle('hidden', !isProductOwner);
    }
    if (productNameInput) {
        productNameInput.required = isProductOwner;
    }
    if (teamNameInput) {
        teamNameInput.required = roleFieldsVisible;
    }
    if (hodContactInput) {
        hodContactInput.required = roleFieldsVisible;
    }
}

function updateContainerAccessSummary() {
    const summary = document.getElementById('containerAccessSummary');
    const checkboxes = [...document.querySelectorAll('#containerAccessList input[name="container-access"]')];
    const selected = checkboxes.filter(cb => cb.checked).map(cb => cb.value);
    summary.textContent = selected.length ? selected.join(', ') : 'Select one or more options';
}

function validateContainerAccess() {
    const checkboxes = [...document.querySelectorAll('#containerAccessList input[name="container-access"]')];
    const error = document.getElementById('containerAccessError');
    const isDeploymentTeam = roleSelect.value === 'Deployment team';
    const selected = checkboxes.some(cb => cb.checked);

    if (!isDeploymentTeam) {
        error.classList.add('hidden');
        return true;
    }

    if (!selected) {
        error.classList.remove('hidden');
        return false;
    }

    error.classList.add('hidden');
    return true;
}

const containerAccessToggle = document.getElementById('containerAccessToggle');
const containerAccessList = document.getElementById('containerAccessList');
const containerCheckboxes = document.querySelectorAll('#containerAccessList input[name="container-access"]');
const reportFilesAddButton = document.getElementById('reportFilesAddButton');
const reportFilesList = document.getElementById('reportFilesList');
const reportFilesContainer = document.getElementById('reportFilesInputs');
const reportSectionPanel = document.getElementById('reportSectionPanel');
const reportSectionToggle = document.getElementById('reportSectionToggle');
const reportSectionToggleIcon = document.getElementById('reportSectionToggleIcon');

let reportFilesPicker = null;
const reportFiles = [];

function createReportFilesPicker() {
    reportFilesPicker = document.createElement('input');
    reportFilesPicker.type = 'file';
    reportFilesPicker.multiple = true;
    reportFilesPicker.accept = '.png,.jpg,.jpeg,.pdf,.docx,.txt';
    reportFilesPicker.className = 'hidden';
    reportFilesPicker.addEventListener('change', () => {
        const files = Array.from(reportFilesPicker.files || []);
        if (!files.length) return;

        const groupId = `report-files-${Date.now()}`;
        reportFilesPicker.dataset.groupId = groupId;
        reportFilesPicker.name = 'report_files';
        reportFilesContainer.appendChild(reportFilesPicker);
        reportFiles.push({ id: groupId, files, input: reportFilesPicker });
        refreshReportFilesList();
        createReportFilesPicker();
    });
}

function refreshReportFilesList() {
    if (!reportFilesList) return;
    reportFilesList.innerHTML = '';
    reportFiles.forEach(group => {
        const groupEl = document.createElement('div');
        groupEl.className = 'flex flex-wrap items-center gap-2 rounded border border-outline-variant bg-surface px-3 py-2';
        const names = document.createElement('span');
        names.className = 'text-body-xs text-on-surface';
        names.textContent = group.files.map(file => file.name).join(', ');
        const removeButton = document.createElement('button');
        removeButton.type = 'button';
        removeButton.className = 'text-error-container underline text-body-xs hover:text-error transition-colors';
        removeButton.textContent = 'Remove';
        removeButton.addEventListener('click', () => removeReportFilesGroup(group.id));
        groupEl.appendChild(names);
        groupEl.appendChild(removeButton);
        reportFilesList.appendChild(groupEl);
    });
}

function removeReportFilesGroup(groupId) {
    const index = reportFiles.findIndex(group => group.id === groupId);
    if (index === -1) return;
    const group = reportFiles[index];
    if (group.input && group.input.parentNode) {
        group.input.parentNode.removeChild(group.input);
    }
    reportFiles.splice(index, 1);
    refreshReportFilesList();
}

createReportFilesPicker();

const reportFilesError = document.getElementById('reportFilesError');
const reportForm = document.querySelector('form[action="/report-status"]');

if (reportFilesAddButton) {
    reportFilesAddButton.addEventListener('click', () => {
        if (reportFilesError) {
            reportFilesError.classList.add('hidden');
            reportFilesError.textContent = '';
        }
        if (reportSectionPanel && reportSectionPanel.classList.contains('hidden')) {
            reportSectionPanel.classList.remove('hidden');
            if (reportSectionToggleIcon) reportSectionToggleIcon.classList.add('rotate-180');
            if (reportSectionToggle) reportSectionToggle.setAttribute('aria-expanded', 'true');
        }
        if (reportFilesPicker) reportFilesPicker.click();
    });
}

if (reportForm) {
    reportForm.addEventListener('submit', (event) => {
        if (!reportFiles.length) {
            event.preventDefault();
            if (reportFilesError) {
                reportFilesError.textContent = 'Please attach at least one file before submitting the report.';
                reportFilesError.classList.remove('hidden');
            } else {
                alert('Please attach at least one file before submitting the report.');
            }
        }
    });
}

if (reportSectionToggle) {
    reportSectionToggle.addEventListener('click', () => {
        if (!reportSectionPanel || !reportSectionToggleIcon) return;
        const panelHidden = reportSectionPanel.classList.toggle('hidden');
        reportSectionToggleIcon.classList.toggle('rotate-180', !panelHidden);
        reportSectionToggle.setAttribute('aria-expanded', (!panelHidden).toString());
    });
}

containerCheckboxes.forEach(cb => cb.addEventListener('change', () => {
    updateContainerAccessSummary();
    validateContainerAccess();
}));

if (reportFilesContainer) {
    reportFilesContainer.style.display = 'none';
}

if (containerAccessToggle) {
    containerAccessToggle.addEventListener('click', () => {
        containerAccessList.classList.toggle('hidden');
    });
}

// Target Device multi-select dropdown logic
function updateTargetDeviceSummary() {
    const summary = document.getElementById('targetDeviceSummary');
    const checkboxes = [...document.querySelectorAll('#targetDeviceList input[name="target-device"]')];
    const selected = checkboxes.filter(cb => cb.checked).map(cb => cb.value);
    summary.textContent = selected.length ? selected.join(', ') : 'Select one or more options';
}

function validateTargetDevice() {
    const checkboxes = [...document.querySelectorAll('#targetDeviceList input[name="target-device"]')];
    const error = document.getElementById('targetDeviceError');
    const selected = checkboxes.some(cb => cb.checked);

    if (!selected) {
        error.classList.remove('hidden');
        return false;
    }

    error.classList.add('hidden');
    return true;
}

const targetDeviceToggle = document.getElementById('targetDeviceToggle');
const targetDeviceList = document.getElementById('targetDeviceList');
const targetDeviceCheckboxes = document.querySelectorAll('#targetDeviceList input[name="target-device"]');

targetDeviceCheckboxes.forEach(cb => cb.addEventListener('change', () => {
    updateTargetDeviceSummary();
    validateTargetDevice();
}));

if (targetDeviceToggle) {
    targetDeviceToggle.addEventListener('click', () => {
        targetDeviceList.classList.toggle('hidden');
    });
}

if (roleSelect) {
    roleSelect.addEventListener('change', updateRoleFields);
    updateRoleFields();
    updateContainerAccessSummary();
}

// Updated form submission validation
const contactFormSubmit = document.querySelector('form[action="/contact"]');
if (contactFormSubmit) {
    contactFormSubmit.addEventListener('submit', (event) => {
        const containerAccessValid = validateContainerAccess();
        const targetDeviceValid = validateTargetDevice();
        
        if (!containerAccessValid) {
            event.preventDefault();
            const isDeploymentTeam = roleSelect.value === 'Deployment team';
            if (isDeploymentTeam) {
                containerAccessList.classList.remove('hidden');
            }
        }
        
        if (!targetDeviceValid) {
            event.preventDefault();
            targetDeviceList.classList.remove('hidden');
        }
    });
}
</script>
</body>
</html>