<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Contact - Singularity Hub</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary-fixed": "#dde1ff",
                        "on-error-container": "#93000a",
                        "inverse-surface": "#2d3133",
                        "on-secondary-fixed-variant": "#3f465c",
                        "surface": "#f7f9fb",
                        "primary": "#003ec7",
                        "on-error": "#ffffff",
                        "surface-container-highest": "#e0e3e5",
                        "surface-tint": "#004ced",
                        "on-primary-fixed": "#001452",
                        "on-background": "#191c1e",
                        "on-tertiary-fixed-variant": "#38485d",
                        "secondary-container": "#dae2fd",
                        "inverse-primary": "#b7c4ff",
                        "on-secondary": "#ffffff",
                        "tertiary-fixed-dim": "#b7c8e1",
                        "error": "#ba1a1a",
                        "surface-container-high": "#e6e8ea",
                        "primary-container": "#0052ff",
                        "surface-bright": "#f7f9fb",
                        "on-primary-fixed-variant": "#0038b6",
                        "outline": "#737688",
                        "surface-container": "#eceef0",
                        "surface-container-low": "#f2f4f6",
                        "surface-container-lowest": "#ffffff",
                        "inverse-on-surface": "#eff1f3",
                        "on-tertiary-container": "#d6e6ff",
                        "on-tertiary-fixed": "#0b1c30",
                        "secondary": "#565e74",
                        "on-primary-container": "#dfe3ff",
                        "surface-dim": "#d8dadc",
                        "surface-variant": "#e0e3e5",
                        "on-tertiary": "#ffffff",
                        "tertiary-fixed": "#d3e4fe",
                        "on-surface": "#191c1e",
                        "primary-fixed-dim": "#b7c4ff",
                        "on-secondary-container": "#5c647a",
                        "tertiary-container": "#57677e",
                        "error-container": "#ffdad6",
                        "background": "#f7f9fb",
                        "on-primary": "#ffffff",
                        "secondary-fixed": "#dae2fd",
                        "secondary-fixed-dim": "#bec6e0",
                        "on-secondary-fixed": "#131b2e",
                        "outline-variant": "#c3c5d9",
                        "tertiary": "#3f4f65",
                        "on-surface-variant": "#434656"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "base": "8px",
                        "container-max": "1200px",
                        "margin-sm": "16px",
                        "margin-md": "32px",
                        "margin-lg": "64px",
                        "gutter": "24px"
                    },
                    "fontFamily": {
                        "headline-md": ["Inter"],
                        "body-lg": ["Inter"],
                        "label-caps": ["Inter"],
                        "headline-xl": ["Inter"],
                        "headline-lg": ["Inter"],
                        "body-md": ["Inter"],
                        "technical-md": ["JetBrains Mono"],
                        "body-sm": ["Inter"],
                        "technical-sm": ["JetBrains Mono"]
                    },
                    "fontSize": {
                        "headline-md": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                        "body-lg": ["18px", { "lineHeight": "28px", "fontWeight": "400" }],
                        "label-caps": ["12px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "700" }],
                        "headline-xl": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "headline-lg": ["32px", { "lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                        "body-md": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "technical-md": ["14px", { "lineHeight": "20px", "fontWeight": "500" }],
                        "body-sm": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "technical-sm": ["12px", { "lineHeight": "16px", "fontWeight": "400" }]
                    }
                }
            }
        }
    </script>
<style>
        /* Ambient shadow utility for subtle depth */
        .shadow-ambient {
            box-shadow: 0px 4px 20px rgba(15, 23, 42, 0.05);
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md antialiased min-h-screen flex flex-col pt-16">
<!-- TopNavBar Component -->
<nav class="bg-surface-container-lowest dark:bg-inverse-surface shadow-sm dark:shadow-none fixed top-0 left-0 w-full z-50 flex items-center justify-between px-margin-md h-16 mx-auto">
<div class="flex items-center gap-margin-md">
<a href="/" class="font-headline-md text-headline-md font-bold text-primary dark:text-inverse-primary tracking-tight hover:opacity-80 transition-opacity" style="text-decoration: none;">Singularity Hub</a>
<div class="hidden md:flex items-center gap-margin-sm h-full">
<a class="text-on-surface-variant dark:text-surface-variant font-medium hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/download">Containers</a>
<a class="text-on-surface-variant dark:text-surface-variant font-medium hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="#">Documentation</a>
<a class="text-primary dark:text-inverse-primary border-b-2 border-primary dark:border-inverse-primary font-bold pb-1 h-full flex items-center" href="/contact">Contact</a>
</div>
</div>
<div class="flex items-center gap-margin-sm">
<!-- Search Bar placeholder for "on_right" -->
<div class="hidden lg:flex items-center bg-surface-container border border-outline-variant rounded px-3 py-1.5 focus-within:border-primary transition-colors">
<span class="material-symbols-outlined text-on-surface-variant mr-2" style="font-size: 18px;">search</span>
<input class="bg-transparent border-none focus:ring-0 text-body-sm font-body-sm p-0 w-48 placeholder-on-surface-variant" placeholder="Search..." type="text"/>
</div>
<div class="flex items-center gap-3">
<button class="text-on-surface-variant hover:text-primary transition-colors mr-2" title="<%= username ? username : 'Guest' %>">
<span class="material-symbols-outlined">account_circle</span>
</button>
<% if (username) { %>
<a class="bg-primary text-on-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container transition-colors ml-2 hidden sm:block" href="/logout" style="text-decoration: none;">
                    Logout
                </a>
<% } else { %>
<a class="bg-primary text-on-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container transition-colors ml-2 hidden sm:block" href="/login" style="text-decoration: none;">
                    Login
                </a>
<% } %>
</div>
</div>
</nav>
<!-- Main Content -->
<main class="flex-grow w-full max-w-container-max mx-auto px-4 md:px-margin-md py-margin-md">
<!-- Status Header -->
<div class="mb-margin-md flex items-center justify-between">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-blue-600 bg-blue-100 p-2 rounded-full" style="font-variation-settings: 'FILL' 1;">contact_support</span>
<div>
<h1 class="font-headline-lg text-headline-lg text-on-background">Contact Us</h1>
<p class="font-body-sm text-body-sm text-on-surface-variant">Get in touch with the Singularity Hub team for support and access requests.</p>
</div>
</div>
</div>
<!-- Contact Sections -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter">
<!-- General Queries -->
<div class="bg-surface-container-lowest border border-surface-variant rounded-lg p-margin-md shadow-[0_4px_20px_rgba(15,23,42,0.05)]">
<div class="flex items-start gap-4">
<span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">help_center</span>
<div class="flex-1">
<h2 class="font-headline-md text-headline-md text-on-surface mb-2">General Queries</h2>
<p class="font-body-md text-body-md text-on-surface-variant mb-4">For any general questions, support requests, or technical assistance, please write to us at:</p>
<a href="mailto:nsmss@cdac.in" class="inline-flex items-center gap-2 bg-primary text-on-primary px-4 py-2 rounded font-technical-md hover:bg-primary-container transition-colors">
<span class="material-symbols-outlined" style="font-size: 18px;">email</span>
nsmss@cdac.in
</a>
</div>
</div>
</div>
<!-- Access Requests -->
<div class="bg-surface-container-lowest border border-surface-variant rounded-lg p-margin-md shadow-[0_4px_20px_rgba(15,23,42,0.05)]">
<div class="flex items-start gap-4">
<span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">person_add</span>
<div class="flex-1">
<h2 class="font-headline-md text-headline-md text-on-surface mb-2">Request Container Access</h2>
<p class="font-body-md text-body-md text-on-surface-variant mb-4">To request access to specific containers, please provide the following details in your email to:</p>
<a href="mailto:nsmss@cdac.in" class="inline-flex items-center gap-2 bg-primary text-on-primary px-4 py-2 rounded font-technical-md hover:bg-primary-container transition-colors mb-4">
<span class="material-symbols-outlined" style="font-size: 18px;">email</span>
nsmss@cdac.in
</a>
<ul class="space-y-2 font-body-md text-body-md text-on-surface-variant">
<li class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary" style="font-size: 16px;">check_circle</span>
<strong>Name:</strong> Your full name
</li>
<li class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary" style="font-size: 16px;">check_circle</span>
<strong>Email:</strong> Your email address
</li>
<li class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary" style="font-size: 16px;">check_circle</span>
<strong>Purpose:</strong> Intended use of the containers
</li>
<li class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary" style="font-size: 16px;">check_circle</span>
<strong>Target Device/Architecture:</strong> e.g., x86_64, ARM64
</li>
<li class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary" style="font-size: 16px;">check_circle</span>
<strong>Organization:</strong> Your affiliated organization
</li>
</ul>
</div>
</div>
</div>
</main>
</body>
</html>