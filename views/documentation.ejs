<main class="flex-grow w-full max-w-container-max mx-auto px-4 md:px-margin-md py-margin-md">
    <div class="mb-margin-md flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
            <p class="text-label-caps uppercase tracking-[0.08em] text-primary font-semibold mb-2">Documentation</p>
            <h1 class="font-headline-lg text-headline-lg text-on-background">PINAKAA Studio User Guide</h1>
            <p class="font-body-md text-body-md text-on-surface-variant mt-3 max-w-2xl">Below is the user guide for the PINAKAA Studio, the steps to request for login access and how to use the application.</p>
        </div>
        <div class="flex flex-wrap gap-3">
            <% 
                let pdfFileName = 'PINAKAA_General_User_Guide.pdf';
                if (role === 'admin' || role === 'Product Owner') {
                    pdfFileName = 'PINAKAA_ProductOwner_Guide.pdf';
                } else if (role === 'Deployment team' || role === 'Deployment Team') {
                    pdfFileName = 'PINAKAA_DeploymentTeam_Guide.pdf';
                }
            %>
            <a href="/download/pdf/<%= pdfFileName %>" class="inline-flex items-center gap-2 bg-primary text-on-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container transition-colors">
                <span class="material-symbols-outlined" style="font-size: 18px;">download</span>
                Download PDF
            </a>
            <a href="/contact" class="inline-flex items-center gap-2 bg-white text-primary border border-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container hover:text-on-primary transition-colors">
                <span class="material-symbols-outlined" style="font-size: 18px;">contact_support</span>
                Contact Support
            </a>
        </div>
    </div>

    <div class="bg-surface-container-lowest border border-surface-variant rounded-lg shadow-ambient overflow-hidden">
        <div class="p-4 md:p-6 bg-surface-container-low">
            <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
                <div class="flex flex-wrap gap-2">
                    <button id="zoom-out" type="button" class="inline-flex items-center gap-2 rounded border border-outline-variant bg-white px-3 py-2 text-body-sm font-semibold text-on-surface hover:border-primary hover:text-primary transition-colors">
                        <span class="material-symbols-outlined" style="font-size: 18px;">zoom_out</span>
                        Zoom out
                    </button>
                    <button id="zoom-in" type="button" class="inline-flex items-center gap-2 rounded border border-outline-variant bg-white px-3 py-2 text-body-sm font-semibold text-on-surface hover:border-primary hover:text-primary transition-colors">
                        <span class="material-symbols-outlined" style="font-size: 18px;">zoom_in</span>
                        Zoom in
                    </button>
                    <button id="prev-page" type="button" class="inline-flex items-center gap-2 rounded border border-outline-variant bg-white px-3 py-2 text-body-sm font-semibold text-on-surface hover:border-primary hover:text-primary transition-colors">
                        <span class="material-symbols-outlined" style="font-size: 18px;">chevron_left</span>
                        Previous
                    </button>
                    <button id="next-page" type="button" class="inline-flex items-center gap-2 rounded border border-outline-variant bg-white px-3 py-2 text-body-sm font-semibold text-on-surface hover:border-primary hover:text-primary transition-colors">
                        Next
                        <span class="material-symbols-outlined" style="font-size: 18px;">chevron_right</span>
                    </button>
                </div>
            </div>
            <div class="rounded-xl border border-outline-variant bg-white p-3">
                <div id="pdf-status" class="mb-3 text-body-sm text-on-surface-variant">Loading PDF…</div>
                <div class="overflow-auto">
                    <canvas id="pdf-canvas" class="mx-auto block"></canvas>
                </div>
                <div class="mt-4 flex flex-wrap items-center justify-between gap-3 text-body-sm text-on-surface-variant">
                    <span id="page-info">Page 1 of 1</span>
                    <span id="zoom-info">100%</span>
                </div>
            </div>
        </div>
    </div>
</main>
<script type="module">
    import * as pdfjsLib from '/pdfjs/build/pdf.mjs';

    pdfjsLib.GlobalWorkerOptions.workerSrc = '/pdfjs/build/pdf.worker.min.mjs';

    // Determine PDF URL based on role
    const role = '<%= role || null %>';
    let pdfUrl = '/assets/PINAKAA_General_User_Guide.pdf';
    
    if (role === 'admin' || role === 'Product Owner') {
        pdfUrl = '/assets/PINAKAA_ProductOwner_Guide.pdf';
    } else if (role === 'Deployment team' || role === 'Deployment Team') {
        pdfUrl = '/assets/PINAKAA_DeploymentTeam_Guide.pdf';
    }

    const canvas = document.getElementById('pdf-canvas');
    const ctx = canvas.getContext('2d');
    const status = document.getElementById('pdf-status');
    const pageInfo = document.getElementById('page-info');
    const zoomInfo = document.getElementById('zoom-info');
    const prevBtn = document.getElementById('prev-page');
    const nextBtn = document.getElementById('next-page');
    const zoomOutBtn = document.getElementById('zoom-out');
    const zoomInBtn = document.getElementById('zoom-in');

    let pdfDoc = null;
    let pageNum = 1;
    let scale = 1.2;

    async function renderPage() {
        if (!pdfDoc) return;

        prevBtn.disabled = pageNum <= 1;
        nextBtn.disabled = pageNum >= pdfDoc.numPages;
        status.textContent = `Rendering page ${pageNum} of ${pdfDoc.numPages}…`;

        const page = await pdfDoc.getPage(pageNum);
        const viewport = page.getViewport({ scale });

        const dpr = window.devicePixelRatio || 1;
        canvas.width = Math.floor(viewport.width * dpr);
        canvas.height = Math.floor(viewport.height * dpr);
        canvas.style.width = `${Math.floor(viewport.width)}px`;
        canvas.style.height = `${Math.floor(viewport.height)}px`;

        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.clearRect(0, 0, viewport.width, viewport.height);

        await page.render({ canvasContext: ctx, viewport }).promise;

        pageInfo.textContent = `Page ${pageNum} of ${pdfDoc.numPages}`;
        zoomInfo.textContent = `${Math.round(scale * 100)}%`;
        status.textContent = `Loaded ${pdfDoc.numPages} page${pdfDoc.numPages === 1 ? '' : 's'}`;
    }

    async function loadPdf() {
        try {
            status.textContent = 'Loading PDF…';
            pdfDoc = await pdfjsLib.getDocument(pdfUrl).promise;
            pageNum = 1;
            await renderPage();
        } catch (error) {
            status.textContent = 'Unable to render the PDF preview.';
            console.error('PDF.js render failed:', error);
        }
    }

    prevBtn.addEventListener('click', async () => {
        if (!pdfDoc || pageNum <= 1) return;
        pageNum -= 1;
        await renderPage();
    });

    nextBtn.addEventListener('click', async () => {
        if (!pdfDoc || pageNum >= pdfDoc.numPages) return;
        pageNum += 1;
        await renderPage();
    });

    zoomOutBtn.addEventListener('click', async () => {
        scale = Math.max(0.75, Math.round((scale - 0.25) * 100) / 100);
        await renderPage();
    });

    zoomInBtn.addEventListener('click', async () => {
        scale = Math.min(2.5, Math.round((scale + 0.25) * 100) / 100);
        await renderPage();
    });

    loadPdf();
</script>
