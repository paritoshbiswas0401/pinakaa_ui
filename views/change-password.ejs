<!DOCTYPE html>
<html class="light" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Change Password | PINAKAA Studio</title>
<link rel="icon" type="image/png" href="/assets/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
<link rel="shortcut icon" href="/assets/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="PINAKAA" />
<link rel="manifest" href="/assets/site.webmanifest" />
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
tailwind.config = {
    darkMode: "class",
    theme: {
        extend: {
            "colors": {
                "primary-fixed": "#FFF6EE",
                "on-error-container": "#93000a",
                "inverse-surface": "#2d3133",
                "on-secondary-fixed-variant": "#3f465c",
                "surface": "#ffffff",
                "primary": "#E84E1B",
                "on-error": "#ffffff",
                "surface-container-highest": "#f4ede8",
                "surface-tint": "#E84E1B",
                "on-primary-fixed": "#4b1b00",
                "on-background": "#191c1e",
                "on-tertiary-fixed-variant": "#38485d",
                "secondary-container": "#FFF1E0",
                "inverse-primary": "#FFD6B3",
                "on-secondary": "#ffffff",
                "tertiary-fixed-dim": "#F7DDBA",
                "error": "#ba1a1a",
                "surface-container-high": "#f7efe8",
                "primary-container": "#FFB67A",
                "surface-bright": "#ffffff",
                "on-primary-fixed-variant": "#9a3000",
                "outline": "#c9a78f",
                "surface-container": "#fff9f6",
                "surface-container-low": "#fffaf7",
                "surface-container-lowest": "#ffffff",
                "inverse-on-surface": "#eff1f3",
                "on-tertiary-container": "#FFF7E6",
                "on-tertiary-fixed": "#0b1c30",
                "secondary": "#6B4226",
                "on-primary-container": "#4b1b00",
                "surface-dim": "#f1e7df",
                "surface-variant": "#f4ebe3",
                "on-tertiary": "#ffffff",
                "tertiary-fixed": "#FFD9AE",
                "on-surface": "#191c1e",
                "primary-fixed-dim": "#FFD6B3",
                "on-secondary-container": "#4a3a2f",
                "tertiary-container": "#7a5a45",
                "error-container": "#ffdad6",
                "background": "#fffaf7",
                "on-primary": "#ffffff",
                "secondary-fixed": "#FFF1E0",
                "secondary-fixed-dim": "#F0E0CF",
                "on-secondary-fixed": "#131b2e",
                "outline-variant": "#e6d3c4",
                "tertiary": "#7a5a45",
                "on-surface-variant": "#434656"
            },
            "borderRadius": {
                "DEFAULT": "0.125rem",
                "lg": "0.25rem",
                "xl": "0.5rem",
                "full": "0.75rem"
            },
            "spacing": {
                "base": "8px",
                "container-max": "1400px",
                "margin-sm": "16px",
                "margin-md": "32px",
                "margin-lg": "64px",
                "gutter": "24px"
            },
            "fontFamily": {
                "headline-md": ["Inter"],
                "body-lg": ["Inter"],
                "label-caps": ["Inter"],
                "headline-xl": ["Inter"],
                "headline-lg": ["Inter"],
                "body-md": ["Inter"],
                "technical-md": ["JetBrains Mono"],
                "body-sm": ["Inter"],
                "technical-sm": ["JetBrains Mono"]
            },
            "fontSize": {
                "headline-md": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                "body-lg": ["18px", { "lineHeight": "28px", "fontWeight": "400" }],
                "label-caps": ["12px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "700" }],
                "headline-xl": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                "headline-lg": ["32px", { "lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                "body-md": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                "technical-md": ["14px", { "lineHeight": "20px", "fontWeight": "500" }],
                "body-sm": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                "technical-sm": ["12px", { "lineHeight": "16px", "fontWeight": "400" }]
            }
        }
    }
}
</script>
<style>
.material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
}
</style>
</head>
<body class="bg-background text-on-background font-body-md antialiased min-h-screen flex flex-col pt-[80px]">
<!-- Navbar -->
<nav class="bg-surface-container-lowest dark:bg-inverse-surface shadow-sm dark:shadow-none fixed top-0 left-0 w-full z-50 flex items-center justify-between px-margin-md h-20">
<div class="flex items-center gap-margin-md">
<a href="/" class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/pinakaa_logo.jpg" alt="Pinakaa Logo" class="h-14 w-auto object-contain"/>
</a>
<div class="hidden md:flex items-center gap-margin-sm h-full">
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/download">Containers</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/documentation">Documentation</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/contact">Contact</a>
<% if (role === 'admin') { %>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/admin">Support</a>
<% } %>
</div>
</div>
<div class="flex items-center gap-margin-sm">
<div class="flex items-center gap-3">
<button class="text-on-surface-variant hover:text-primary transition-colors mr-2" title="<%= username ? username : 'Guest' %>">
<span class="material-symbols-outlined">account_circle</span>
</button>
<a class="bg-primary text-on-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container transition-colors ml-2 hidden sm:block" href="/logout" style="text-decoration: none;">Logout</a>
<div class="flex items-center gap-margin-md">
<a class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/nsm_logo.png" alt="NSM Logo" class="h-14 w-auto object-contain" style="height: 70px;"/>
</a>
</div>
<div class="flex items-center gap-margin-md">
<a class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/cdac_logo_blue.png" alt="C-DAC Logo" class="h-14 w-auto object-contain"/>
</a>
</div>
</div>
</div>
</nav>

<!-- Main Content -->
<main class="flex-grow w-full max-w-container-max mx-auto px-4 md:px-margin-md py-margin-md">
<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
<!-- Left Column: Form Panel -->
<div class="lg:col-span-6 flex flex-col gap-margin-md">
<div class="bg-surface-container-lowest border border-outline-variant shadow-[0px_4px_20px_rgba(15,23,42,0.05)] rounded-DEFAULT p-margin-md flex flex-col h-full">
<div class="flex flex-col mb-margin-md">
<h1 class="font-headline-lg text-headline-lg text-on-surface mb-2 flex items-center gap-base">
<span class="material-symbols-outlined text-primary" style="font-size: 28px;">lock</span>
Change Password
</h1>
<p class="font-body-md text-body-md text-on-surface-variant">Keep your account secure by updating your password regularly.</p>
</div>

<% if (error) { %>
<div class="mb-margin-md rounded-xl border border-error-container bg-error-container/10 p-4 text-error">
<div class="flex gap-2">
<span class="material-symbols-outlined flex-shrink-0">error</span>
<div>
<h3 class="font-headline-sm text-headline-sm font-semibold">Error</h3>
<p class="font-body-sm text-body-sm"><%= error %></p>
</div>
</div>
</div>
<% } %>

<% if (success) { %>
<div class="mb-margin-md rounded-xl border border-primary-container bg-primary-fixed p-4 text-on-primary-fixed">
<div class="flex gap-2">
<span class="material-symbols-outlined flex-shrink-0">check_circle</span>
<div>
<h3 class="font-headline-sm text-headline-sm font-semibold text-primary">Success</h3>
<p class="font-body-sm text-body-sm"><%= success %></p>
</div>
</div>
</div>
<% } %>

<form method="POST" action="/change-password" class="space-y-margin-md flex flex-col">
<div class="flex flex-col gap-2">
<label class="font-body-sm font-semibold text-on-surface" for="currentPassword">Current Password</label>
<input 
    id="currentPassword" 
    name="currentPassword" 
    type="password" 
    required 
    class="w-full rounded border border-outline-variant px-4 py-2.5 bg-surface text-body-sm text-on-surface placeholder-on-surface-variant focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none transition-colors"
    placeholder="Enter your current password"
/>
</div>

<div class="flex flex-col gap-2">
<label class="font-body-sm font-semibold text-on-surface" for="newPassword">New Password</label>
<input 
    id="newPassword" 
    name="newPassword" 
    type="password" 
    required 
    class="w-full rounded border border-outline-variant px-4 py-2.5 bg-surface text-body-sm text-on-surface placeholder-on-surface-variant focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none transition-colors"
    placeholder="Enter your new password"
/>
<p class="font-body-sm text-body-sm text-on-surface-variant">Minimum 6 characters</p>
</div>

<div class="flex flex-col gap-2">
<label class="font-body-sm font-semibold text-on-surface" for="confirmPassword">Confirm New Password</label>
<input 
    id="confirmPassword" 
    name="confirmPassword" 
    type="password" 
    required 
    class="w-full rounded border border-outline-variant px-4 py-2.5 bg-surface text-body-sm text-on-surface placeholder-on-surface-variant focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none transition-colors"
    placeholder="Re-enter your new password"
/>
</div>

<div class="flex gap-3 pt-4">
<button type="submit" class="flex-1 inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-container text-on-primary px-4 py-2.5 rounded font-semibold text-body-sm transition-colors">
<span class="material-symbols-outlined" style="font-size: 20px;">check</span>
Update Password
</button>
<a href="/" class="flex-1 inline-flex items-center justify-center gap-2 border border-outline bg-surface-container-lowest text-on-surface px-4 py-2.5 rounded font-semibold text-body-sm hover:bg-surface-container transition-colors" style="text-decoration: none;">
<span class="material-symbols-outlined" style="font-size: 20px;">close</span>
Cancel
</a>
</div>
</form>

<div class="mt-margin-md pt-margin-md border-t border-outline-variant">
<p class="font-body-sm text-body-sm text-on-surface-variant">
<strong>Password Security Tips:</strong>
<ul class="list-disc list-inside mt-2 space-y-1">
<li>Use a mix of uppercase, lowercase, numbers, and symbols</li>
<li>Avoid using personal information like names or birthdates</li>
<li>Don't reuse passwords from other accounts</li>
<li>Change your password periodically for better security</li>
</ul>
</p>
</div>
</div>
</div>

<!-- Right Column: Info Panel -->
<div class="lg:col-span-6 flex flex-col gap-margin-md">
<div class="bg-surface-container-lowest border border-outline-variant shadow-[0px_4px_20px_rgba(15,23,42,0.05)] rounded-DEFAULT p-margin-md">
<h2 class="font-headline-md text-headline-md text-on-surface mb-4 flex items-center gap-base">
<span class="material-symbols-outlined text-secondary">shield</span>
Account Security
</h2>
<div class="space-y-4">
<div class="flex gap-3">
<span class="material-symbols-outlined text-primary flex-shrink-0 pt-1">check_circle</span>
<div>
<h3 class="font-body-sm font-semibold text-on-surface">Strong Password Required</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Your password must be at least 6 characters long.</p>
</div>
</div>
<div class="flex gap-3">
<span class="material-symbols-outlined text-primary flex-shrink-0 pt-1">check_circle</span>
<div>
<h3 class="font-body-sm font-semibold text-on-surface">Confirmation Required</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">You'll be logged out after changing your password for security.</p>
</div>
</div>
<div class="flex gap-3">
<span class="material-symbols-outlined text-primary flex-shrink-0 pt-1">check_circle</span>
<div>
<h3 class="font-body-sm font-semibold text-on-surface">Session Management</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">All active sessions will be terminated after password change.</p>
</div>
</div>
</div>
</div>

<div class="bg-primary-fixed border border-primary-container shadow-[0px_4px_20px_rgba(232,78,27,0.08)] rounded-DEFAULT p-margin-md">
<h2 class="font-headline-md text-headline-md text-primary mb-4">Need Help?</h2>
<p class="font-body-md text-body-md text-on-surface-variant mb-4">If you're having trouble with your password or need to reset it, please contact our support team.</p>
<a href="/contact" class="inline-flex items-center gap-2 text-primary hover:text-on-primary font-semibold text-body-sm" style="text-decoration: none;">
<span class="material-symbols-outlined">help</span>
Contact Support
</a>
</div>
</div>
</div>
</main>

<!-- Footer -->
<footer class="bg-surface-container-low dark:bg-inverse-surface border-t border-outline-variant dark:border-outline mt-auto w-full py-margin-md px-margin-md flex flex-col md:flex-row justify-between items-center gap-base">
<div class="font-headline-sm text-headline-sm font-semibold text-on-surface dark:text-inverse-on-surface text-center md:text-left">
© 2026 System Software Development Group, HPC-STU, C-DAC, Bengaluru. All rights reserved.
</div>
<div class="flex flex-wrap justify-center gap-margin-sm">
<a class="font-body-sm text-body-sm text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Terms of Service</a>
<a class="font-body-sm text-body-sm text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Privacy Policy</a>
<a class="font-body-sm text-body-sm text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Security Audit</a>
<a class="font-body-sm text-body-sm text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">API Reference</a>
<a class="font-body-sm text-body-sm text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Status</a>
</div>
</footer>
</body>
</html>
