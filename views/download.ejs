<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Container Download - PINAKAA Studio</title>
<link rel="icon" type="image/png" href="/assets/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
<link rel="shortcut icon" href="/assets/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="PINAKAA" />
<link rel="manifest" href="/assets/site.webmanifest" />
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

<link rel="stylesheet" href="/css/style.css" />
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .toggle-panel {
            max-height: 0;
            opacity: 0;
            overflow: hidden;
            transition: max-height 0.3s ease, opacity 0.3s ease;
        }
        .toggle-panel.open {
            max-height: 1000px;
            opacity: 1;
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md antialiased min-h-screen flex flex-col pt-[80px]">
<!-- TopNavBar Component -->
<nav class="bg-surface-container-lowest dark:bg-inverse-surface shadow-sm dark:shadow-none fixed top-0 left-0 w-full z-50 flex items-center justify-between px-margin-md h-20 mx-auto">
<div class="flex items-center gap-margin-md">
<a href="/" class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/pinakaa_logo.jpg" alt="Pinakaa Logo" class="h-14 w-auto object-contain"/>
</a>
<div class="hidden md:flex items-center gap-margin-sm h-full">
<% if (role === 'admin') { %>
<a class="text-body-md text-primary dark:text-inverse-primary px-3 py-2 border-b-2 border-primary dark:border-inverse-primary font-bold pb-1 h-full flex items-center" href="/download">Containers</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/documentation">Documentation</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/contact" title="Request container access: Name, Email, Purpose, Target Device/Architecture, Organization">Contact</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/admin">Support</a>
<% } else { %>
<% if (role !== 'Product Owner') { %>
<a class="text-body-md text-primary dark:text-inverse-primary px-3 py-2 border-b-2 border-primary dark:border-inverse-primary font-bold pb-1 h-full flex items-center" href="/download">Containers</a>
<% } %>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/documentation">Documentation</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/contact" title="Request container access: Name, Email, Purpose, Target Device/Architecture, Organization">Contact</a>
<% } %>
</div>
</div>
<div class="flex items-center gap-margin-sm">
<!-- Search Bar placeholder for "on_right" -->
<!-- <div class="hidden lg:flex items-center bg-surface-container border border-outline-variant rounded px-3 py-1.5 focus-within:border-primary transition-colors">
<span class="material-symbols-outlined text-on-surface-variant mr-2" style="font-size: 18px;">search</span>
<input class="bg-transparent border-none focus:ring-0 text-body-sm font-body-sm p-0 w-48 placeholder-on-surface-variant" placeholder="Search..." type="text"/>
</div> -->
<div class="flex items-center gap-3">
<button class="text-on-surface-variant hover:text-primary transition-colors mr-2" title="<%= username ? username : 'Guest' %>">
<span class="material-symbols-outlined">account_circle</span>
</button>
<% if (username) { %>
<a class="bg-white text-primary border border-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container hover:text-on-primary transition-colors ml-2 hidden sm:block" href="/change-password" style="text-decoration: none;">
                    Change Password
                </a>
<a class="bg-primary text-on-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container transition-colors ml-2 hidden sm:block" href="/logout" style="text-decoration: none;">
                    Logout
                </a>
<% } else { %>
<a class="bg-primary text-on-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container transition-colors ml-2 hidden sm:block" href="/login" style="text-decoration: none;">
                    Login
                </a>
<% } %>

<div class="flex items-center gap-margin-md">
<a class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/nsm_logo.png" alt="NSM Logo" class="h-14 w-auto object-contain" style="height: 70px;"/>
</a>
</div>
<div class="flex items-center gap-margin-md">
<a class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/cdac_logo_blue.png" alt="C-DAC Logo" class="h-14 w-auto object-contain"/>
</a>
</div>

</div>
</div>
</nav>
<!-- Main Content -->
<main class="flex-grow w-full max-w-container-max mx-auto px-4 md:px-margin-md py-margin-md">
<!-- Status Header -->
 <div class="flex items-center gap-3">
<!-- <span class="material-symbols-outlined text-green-600 bg-green-100 p-2 rounded-full" style="font-variation-settings: 'FILL' 1;">verified_user</span> -->
<div>
<!-- <h1 class="font-headline-lg text-headline-lg text-on-background"><%= headerLabel %></h1> -->
<% if (personalized) { %>
<div class="mt-2 inline-flex items-center gap-2 bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full font-technical-sm">
<span class="material-symbols-outlined" style="font-size: 16px;">badge</span>
    Showing authorized containers for: <strong class="font-bold"><%= username %></strong>
</div>
<% } %>
</div>
</div>
<div class="mb-margin-md flex items-start justify-between">
<% if (warningMessage) { %>
<div class="mb-6 rounded-xl border border-error-container bg-error-container/10 p-4 text-error">
    <h2 class="font-headline-md text-headline-md mb-2">Access Restricted</h2>
    <p class="font-body-sm text-body-sm"> <%= warningMessage %> Please contact your administrator or submit a request for Deployment Team access if you need container downloads.</p>
</div>
<% } %>
<!-- Dashboard Layout Grid -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
<!-- Left Column: Primary Download Area -->
<div class="lg:col-span-12 flex flex-col gap-gutter">

<% if (!warningMessage && containers.length > 0) { %>
    <div class="bg-surface-container-lowest border border-surface-variant rounded-lg overflow-hidden shadow-sm">
        <% if (!personalized) { %>
        <div class="px-4 py-4 border-b border-surface-variant">
            <h2 class="font-headline-md text-headline-md text-on-surface mb-2"><%= headerLabel %></h2>
        </div>
        <% } %>
        <div class="grid grid-cols-12 gap-4 px-4 py-4 border-b border-surface-variant text-on-surface-variant font-label-caps text-label-caps uppercase tracking-[0.08em]">
            <div class="col-span-11">Container</div>
            <div class="col-span-1 text-right">Action</div>
        </div>
        <% containers.forEach(function(container, index) { %>
            <div class="grid grid-cols-12 gap-4 px-4 py-3 hover:bg-surface-container transition-colors">
                <div class="col-span-11">
                    <div class="flex flex-col gap-2">
                        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
                            <div>
                                <div class="font-headline-md text-headline-md text-on-surface"><%= container.title %></div>
                                <div class="mt-2 flex flex-wrap gap-2">
                                    <% if (container.version) { %>
                                    <span class="bg-surface-container text-on-surface border border-outline-variant px-2 py-1 rounded-full text-technical-sm">Version: <%= container.version %></span>
                                    <% } %>
                                    <span class="bg-surface-container text-on-surface border border-outline-variant px-2 py-1 rounded-full text-technical-sm"><%= container.arch %></span>
                                    <span class="bg-surface-container text-on-surface border border-outline-variant px-2 py-1 rounded-full text-technical-sm"><%= container.access %></span>
                                    <span class="bg-primary-container text-on-primary-container border border-primary px-2 py-1 rounded-full text-technical-sm font-semibold">
                                        <span class="material-symbols-outlined" style="font-size: 14px; vertical-align: middle;">download</span>
                                        <%= container.downloads %>
                                    </span>
                                </div>
                            </div>
                            <button type="button" data-toggle-desc="desc-<%= index %>" class="toggle-desc-btn inline-flex items-center gap-2 text-primary font-semibold">
                                <span class="material-symbols-outlined text-[18px]">expand_more</span>
                                Description
                            </button>
                        </div>
                        <div id="desc-<%= index %>" class="toggle-panel rounded-lg border border-surface-variant bg-surface-container-lowest p-4 text-body-sm text-on-surface-variant">
                            <div><%= container.description %></div>
                            <div class="mt-3 text-xs text-on-surface-variant">Filename: <strong><%= container.filename %></strong></div>
                        </div>
                    </div>
                </div>
                <div class="col-span-1 flex items-start justify-end text-right">
                    <button type="button" data-download-file="<%= container.filename %>" class="download-btn inline-flex items-center justify-center bg-primary hover:bg-primary-container text-on-primary text-body-sm font-semibold px-4 py-2 rounded transition-colors">
                        <span class="material-symbols-outlined text-[18px] mr-2">download</span>
                        Get
                    </button>
                </div>
            </div>
        <% }); %>
    </div>
<% } else if (!warningMessage) { %>
    <div class="bg-surface-container-lowest border border-surface-variant rounded-lg p-margin-md text-center">
        <h2 class="font-headline-md text-headline-md text-on-surface mb-2">No matching containers found</h2>
        <p class="font-body-md text-body-md text-on-surface-variant">Your profile and architecture do not match any available containers/spack packages yet. Please request additional access or try again later.</p>
    </div>
<% } %>
</div>
</div>
</main>
<footer class="bg-surface-container-low dark:bg-inverse-surface border-t border-outline-variant dark:border-outline mt-auto w-full py-margin-md px-margin-md flex flex-col md:flex-row justify-between items-center gap-base mx-auto">
    <div class="font-headline-sm text-headline-sm font-semibold text-on-surface dark:text-inverse-on-surface text-center md:text-left">
        © 2026 System Software Development Group, HPC-STU, C-DAC, Bengaluru. All rights reserved.
    </div>
    <div class="flex flex-wrap justify-center gap-margin-sm">
        <a class="font-body-sm text-body-sm text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Terms of Service</a>
        <a class="font-body-sm text-body-sm text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Privacy Policy</a>
        <a class="font-body-sm text-body-sm text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Security Audit</a>
        <a class="font-body-sm text-body-sm text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">API Reference</a>
        <a class="font-body-sm text-body-sm text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Status</a>
    </div>
</footer>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Toggle description panels
    document.querySelectorAll('.toggle-desc-btn').forEach(button => {
        button.addEventListener('click', function() {
            const panelId = this.getAttribute('data-toggle-desc');
            const panel = document.getElementById(panelId);
            if (!panel) {
                console.error('Panel not found:', panelId);
                return;
            }
            const opened = panel.classList.toggle('open');
            const icon = this.querySelector('.material-symbols-outlined');
            if (icon) {
                icon.textContent = opened ? 'expand_less' : 'expand_more';
            }
            this.setAttribute('aria-expanded', String(opened));
        });
    });

    // Handle downloads
    document.querySelectorAll('.download-btn').forEach(button => {
        button.addEventListener('click', function() {
            const filename = this.getAttribute('data-download-file');
            if (!filename) {
                console.error('Filename is empty');
                return;
            }
            window.location.href = '/download/file/' + encodeURIComponent(filename);
        });
    });
});
</script>

</body></html>