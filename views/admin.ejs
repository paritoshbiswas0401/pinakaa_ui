<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Admin Dashboard - User Management - Singularity Hub</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "surface-container-highest": "#e0e3e5",
                    "surface-variant": "#e0e3e5",
                    "on-tertiary-container": "#d6e6ff",
                    "surface-tint": "#004ced",
                    "surface": "#f7f9fb",
                    "error-container": "#ffdad6",
                    "outline-variant": "#c3c5d9",
                    "on-tertiary-fixed": "#0b1c30",
                    "on-primary-fixed-variant": "#0038b6",
                    "tertiary-fixed-dim": "#b7c8e1",
                    "inverse-on-surface": "#eff1f3",
                    "on-background": "#191c1e",
                    "on-error-container": "#93000a",
                    "surface-container-low": "#f2f4f6",
                    "on-primary-fixed": "#001452",
                    "primary-container": "#0052ff",
                    "on-tertiary-fixed-variant": "#38485d",
                    "on-surface": "#191c1e",
                    "on-secondary-fixed": "#131b2e",
                    "secondary-fixed-dim": "#bec6e0",
                    "on-secondary-container": "#5c647a",
                    "primary-fixed": "#dde1ff",
                    "tertiary-fixed": "#d3e4fe",
                    "error": "#ba1a1a",
                    "tertiary-container": "#57677e",
                    "surface-container-high": "#e6e8ea",
                    "background": "#f7f9fb",
                    "outline": "#737688",
                    "surface-container-lowest": "#ffffff",
                    "secondary": "#565e74",
                    "secondary-container": "#dae2fd",
                    "surface-container": "#eceef0",
                    "on-surface-variant": "#434656",
                    "on-secondary": "#ffffff",
                    "on-error": "#ffffff",
                    "surface-bright": "#f7f9fb",
                    "on-secondary-fixed-variant": "#3f465c",
                    "tertiary": "#3f4f65",
                    "primary": "#003ec7",
                    "surface-dim": "#d8dadc",
                    "inverse-surface": "#2d3133",
                    "on-tertiary": "#ffffff",
                    "primary-fixed-dim": "#b7c4ff",
                    "on-primary-container": "#dfe3ff",
                    "inverse-primary": "#b7c4ff",
                    "on-primary": "#ffffff",
                    "secondary-fixed": "#dae2fd"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "spacing": {
                    "margin-sm": "16px",
                    "margin-lg": "64px",
                    "base": "8px",
                    "container-max": "1200px",
                    "margin-md": "32px",
                    "gutter": "24px"
            },
            "fontFamily": {
                    "technical-sm": [
                            "JetBrains Mono"
                    ],
                    "label-caps": [
                            "Inter"
                    ],
                    "headline-md": [
                            "Inter"
                    ],
                    "body-sm": [
                            "Inter"
                    ],
                    "technical-md": [
                            "JetBrains Mono"
                    ],
                    "body-md": [
                            "Inter"
                    ],
                    "headline-lg": [
                            "Inter"
                    ],
                    "headline-xl": [
                            "Inter"
                    ],
                    "body-lg": [
                            "Inter"
                    ]
            },
            "fontSize": {
                    "technical-sm": [
                            "12px",
                            {
                                    "lineHeight": "16px",
                                    "fontWeight": "400"
                            }
                    ],
                    "label-caps": [
                            "12px",
                            {
                                    "lineHeight": "16px",
                                    "letterSpacing": "0.05em",
                                    "fontWeight": "700"
                            }
                    ],
                    "headline-md": [
                            "24px",
                            {
                                    "lineHeight": "32px",
                                    "fontWeight": "600"
                            }
                    ],
                    "body-sm": [
                            "14px",
                            {
                                    "lineHeight": "20px",
                                    "fontWeight": "400"
                            }
                    ],
                    "technical-md": [
                            "14px",
                            {
                                    "lineHeight": "20px",
                                    "fontWeight": "500"
                            }
                    ],
                    "body-md": [
                            "16px",
                            {
                                    "lineHeight": "24px",
                                    "fontWeight": "400"
                            }
                    ],
                    "headline-lg": [
                            "32px",
                            {
                                    "lineHeight": "40px",
                                    "letterSpacing": "-0.01em",
                                    "fontWeight": "600"
                            }
                    ],
                    "headline-xl": [
                            "48px",
                            {
                                    "lineHeight": "56px",
                                    "letterSpacing": "-0.02em",
                                    "fontWeight": "700"
                            }
                    ],
                    "body-lg": [
                            "18px",
                            {
                                    "lineHeight": "28px",
                                    "fontWeight": "400"
                            }
                    ]
            }
          },
        },
      }
    </script>
</head>
<body class="bg-background text-on-surface font-body-md antialiased flex flex-col min-h-screen">
<!-- TopNavBar (Shared Component) -->
<header class="fixed top-0 left-0 w-full z-50 flex items-center justify-between px-margin-md h-16 mx-auto bg-surface-container-lowest dark:bg-inverse-surface border-b border-outline-variant dark:border-outline shadow-sm dark:shadow-none transition-all duration-150">
<div class="flex items-center gap-margin-md">
<a class="font-headline-md text-headline-md font-bold text-primary dark:text-inverse-primary tracking-tight hover:opacity-80 transition-opacity" href="/">Singularity Hub</a>
<nav class="hidden md:flex gap-margin-sm">
<a class="text-on-surface-variant dark:text-surface-variant font-medium hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200" href="/download">Containers</a>
<a class="text-on-surface-variant dark:text-surface-variant font-medium hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200" href="#">Documentation</a>
<a class="text-primary dark:text-inverse-primary border-b-2 border-primary dark:border-inverse-primary font-bold pb-1" href="#">Support</a>
<a class="text-on-surface-variant dark:text-surface-variant font-medium hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200" href="/contact" title="Request container access: Name, Email, Purpose, Target Device/Architecture, Organization">Contact</a>
</nav>
</div>
<div class="flex items-center gap-margin-sm">
<a class="text-primary dark:text-inverse-primary font-medium hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200" href="/logout" style="text-decoration: none;">
                    Logout
                </a>
<div class="flex gap-base text-primary dark:text-inverse-primary">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;" title="<%= username ? username : 'Guest' %>">account_circle</span>
</div>
</div>
</header>
<!-- Main Content Canvas -->
<main class="flex-grow pt-[80px] pb-margin-lg px-margin-sm md:px-margin-md max-w-container-max mx-auto w-full">
<div class="mb-margin-md">
<h1 class="font-headline-lg text-headline-lg text-on-surface mb-base">User Management</h1>
<p class="font-body-md text-body-md text-on-surface-variant">Administer secure access and review active authorizations.</p>
</div>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
<!-- Add User Form Panel -->
<div class="lg:col-span-4 bg-surface-container-lowest border border-outline-variant shadow-[0px_4px_20px_rgba(15,23,42,0.05)] rounded-DEFAULT p-margin-sm">
<h2 class="font-headline-md text-headline-md text-on-surface mb-margin-sm flex items-center gap-base">
<span class="material-symbols-outlined text-primary">person_add</span>
                    Provision Access
                </h2>
<form class="space-y-margin-sm">
<div>
<label class="block font-label-caps text-label-caps text-on-surface-variant mb-base" for="username">Username</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">person</span>
<input class="w-full pl-10 pr-3 py-2 bg-surface-container-low border border-outline-variant rounded-DEFAULT focus:border-primary focus:ring-1 focus:ring-primary font-technical-md text-technical-md text-on-surface transition-colors" id="username" placeholder="e.g. jdoe_hpc" type="text"/>
</div>
</div>
<div>
<label class="block font-label-caps text-label-caps text-on-surface-variant mb-base" for="email">Institutional Email</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">mail</span>
<input class="w-full pl-10 pr-3 py-2 bg-surface-container-low border border-outline-variant rounded-DEFAULT focus:border-primary focus:ring-1 focus:ring-primary font-body-sm text-body-sm text-on-surface transition-colors" id="email" placeholder="user@institution.edu" type="email"/>
</div>
</div>
<div>
<label class="block font-label-caps text-label-caps text-on-surface-variant mb-base" for="password">Initial Password</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">lock</span>
<input class="w-full pl-10 pr-3 py-2 bg-surface-container-low border border-outline-variant rounded-DEFAULT focus:border-primary focus:ring-1 focus:ring-primary font-technical-md text-technical-md text-on-surface transition-colors" id="password" placeholder="••••••••" type="password"/>
</div>
</div>
<div>
<label class="block font-label-caps text-label-caps text-on-surface-variant mb-base" for="purpose">Purpose for Download</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-3 text-outline text-[18px]">description</span>
<textarea class="w-full pl-10 pr-3 py-2 bg-surface-container-low border border-outline-variant rounded-DEFAULT focus:border-primary focus:ring-1 focus:ring-primary font-body-sm text-body-sm text-on-surface transition-colors" id="purpose" placeholder="Brief description of research or project..." rows="3"></textarea>
</div>
</div>
<div>
<label class="block font-label-caps text-label-caps text-on-surface-variant mb-base" for="container-access">Container Access</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">package_2</span>
<select class="w-full pl-10 pr-3 py-2 bg-surface-container-low border border-outline-variant rounded-DEFAULT focus:border-primary focus:ring-1 focus:ring-primary font-body-sm text-body-sm text-on-surface transition-colors appearance-none" id="container-access">
<option>Standard CPU</option>
<option>GPU-Optimized</option>
<option>Security Audited</option>
<option>All Containers</option>
</select>
<span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none">arrow_drop_down</span>
</div>
</div><div>
<label class="block font-label-caps text-label-caps text-on-surface-variant mb-base" for="arch">Target Architecture</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">memory</span>
<select class="w-full pl-10 pr-3 py-2 bg-surface-container-low border border-outline-variant rounded-DEFAULT focus:border-primary focus:ring-1 focus:ring-primary font-technical-md text-technical-md text-on-surface transition-colors appearance-none" id="arch">
<option>x86_64</option>
<option>aarch64</option>
<option>ppc64le</option>
</select>
<span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none">arrow_drop_down</span>
</div>
</div>
<div>
<label class="block font-label-caps text-label-caps text-on-surface-variant mb-base" for="organization">Organization</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">business</span>
<input class="w-full pl-10 pr-3 py-2 bg-surface-container-low border border-outline-variant rounded-DEFAULT focus:border-primary focus:ring-1 focus:ring-primary font-body-sm text-body-sm text-on-surface transition-colors" id="organization" placeholder="e.g. Stanford University" type="text"/>
</div>
</div>
<button class="w-full bg-primary text-on-primary font-body-md text-body-md font-semibold py-2 px-4 rounded-DEFAULT hover:bg-primary-container hover:text-on-primary-container transition-colors flex items-center justify-center gap-base" type="button">
<span class="material-symbols-outlined text-[20px]">add_circle</span>
                        Authorize User
                    </button>
</form>
</div>
<!-- Authorized Users Table Panel -->
<div class="lg:col-span-8 bg-surface-container-lowest border border-outline-variant shadow-[0px_4px_20px_rgba(15,23,42,0.05)] rounded-DEFAULT p-margin-sm flex flex-col h-full">
<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-margin-sm gap-margin-sm">
<h2 class="font-headline-md text-headline-md text-on-surface flex items-center gap-base">
<span class="material-symbols-outlined text-secondary">group</span>
                        Active Authorizations
                    </h2>
<div class="relative w-full sm:w-auto">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">search</span>
<input class="w-full sm:w-64 pl-10 pr-3 py-1.5 bg-surface-container-low border border-outline-variant rounded-DEFAULT focus:border-primary focus:ring-1 focus:ring-primary font-body-sm text-body-sm text-on-surface transition-colors" placeholder="Search logs..." type="text"/>
</div>
</div>
<div class="overflow-x-auto flex-grow rounded-DEFAULT border border-outline-variant bg-surface">
<table class="w-full text-left border-collapse">
<thead>
<tr class="bg-surface-container-low border-b border-outline-variant">
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">User Identifier</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Purpose</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Organization</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Architecture</th><th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Container Access</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Status</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant text-right">Actions</th>
</tr>
</thead>
<tbody class="font-technical-sm text-technical-sm text-on-surface divide-y divide-outline-variant">
    <% users.forEach(function(user) { %>
    <tr class="hover:bg-surface-container-lowest transition-colors">
        <td class="py-3 px-4">
            <div class="flex flex-col">
                <span class="font-technical-md text-technical-md text-primary"><%= user.username %></span>
                <span class="text-on-surface-variant"><%= user.email %></span>
            </div>
        </td>
        <td class="py-3 px-4 font-body-sm text-body-sm"><%= user.purpose %></td>
        <td class="py-3 px-4 font-body-sm text-body-sm"><%= user.organization || 'N/A' %></td>
        <td class="py-3 px-4"><%= user.target_device %></td>
        <td class="py-3 px-4"><%= user.container_access %></td>
        <td class="py-3 px-4">Active</td>
        <td class="py-3 px-4 text-right">
            <button class="text-error hover:text-on-error-container">Revoke</button>
        </td>
    </tr>
    <% }); %>
</tbody>
</table>
</div>
<div class="mt-base flex justify-between items-center text-on-surface-variant font-technical-sm text-technical-sm">
<span>Showing 3 of 142 authorized entities</span>
<div class="flex gap-2">
<button class="p-1 hover:bg-surface-container-high rounded-DEFAULT transition-colors"><span class="material-symbols-outlined text-[18px]">chevron_left</span></button>
<button class="p-1 hover:bg-surface-container-high rounded-DEFAULT transition-colors"><span class="material-symbols-outlined text-[18px]">chevron_right</span></button>
</div>
</div>
</div>
</div>
</main>
<!-- Footer (Shared Component) -->
<footer class="w-full py-margin-md px-margin-md flex flex-col md:flex-row justify-between items-center gap-base max-w-container-max mx-auto bg-surface-container-low dark:bg-inverse-surface border-t border-outline-variant dark:border-outline mt-auto">
<div class="flex flex-col items-center md:items-start gap-1">
<span class="font-headline-sm text-headline-sm font-semibold text-on-surface dark:text-inverse-on-surface">Singularity Hub</span>
<p class="font-body-sm text-body-sm text-secondary dark:text-secondary-fixed">© 2024 HPC Systems. All rights reserved. Secure Singularity Container Distribution.</p>
</div>
<nav class="flex flex-wrap justify-center gap-margin-sm font-technical-sm text-technical-sm">
<a class="text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Terms of Service</a>
<a class="text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Privacy Policy</a>
<a class="text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Security Audit</a>
<a class="text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">API Reference</a>
<a class="text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Status</a>
</nav>
</footer>
<script>
document.querySelector('button[type="button"]').addEventListener('click', async () => {
    const username = document.getElementById('username').value;
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    const purpose = document.getElementById('purpose').value;
    const containerAccess = document.getElementById('container-access').value;
    const arch = document.getElementById('arch').value;
    const organization = document.getElementById('organization').value;

    if (!username || !email || !password || !purpose || !organization) {
        alert('Please fill all fields');
        return;
    }

    const response = await fetch('/admin/add-user', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, email, password, purpose, 'container-access': containerAccess, arch, organization })
    });

    const result = await response.json();
    if (result.success) {
        alert('User added successfully');
        location.reload();
    } else {
        alert('Error: ' + result.error);
    }
});
</script>
</body></html>