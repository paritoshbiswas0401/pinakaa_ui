<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Admin Dashboard - User Management - PINAKAA Studio</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "primary-fixed": "#FFF6EE",
                    "on-error-container": "#93000a",
                    "inverse-surface": "#2d3133",
                    "on-secondary-fixed-variant": "#3f465c",
                    "surface": "#ffffff",
                    "primary": "#E84E1B",
                    "on-error": "#ffffff",
                    "surface-container-highest": "#f4ede8",
                    "surface-tint": "#E84E1B",
                    "on-primary-fixed": "#4b1b00",
                    "on-background": "#191c1e",
                    "on-tertiary-fixed-variant": "#38485d",
                    "secondary-container": "#FFF1E0",
                    "inverse-primary": "#FFD6B3",
                    "on-secondary": "#ffffff",
                    "tertiary-fixed-dim": "#F7DDBA",
                    "error": "#ba1a1a",
                    "surface-container-high": "#f7efe8",
                    "primary-container": "#FFB67A",
                    "surface-bright": "#ffffff",
                    "on-primary-fixed-variant": "#9a3000",
                    "outline": "#c9a78f",
                    "surface-container": "#fff9f6",
                    "surface-container-low": "#fffaf7",
                    "surface-container-lowest": "#ffffff",
                    "inverse-on-surface": "#eff1f3",
                    "on-tertiary-container": "#FFF7E6",
                    "on-tertiary-fixed": "#0b1c30",
                    "secondary": "#6B4226",
                    "on-primary-container": "#4b1b00",
                    "surface-dim": "#f1e7df",
                    "surface-variant": "#f4ebe3",
                    "on-tertiary": "#ffffff",
                    "tertiary-fixed": "#FFD9AE",
                    "on-surface": "#191c1e",
                    "primary-fixed-dim": "#FFD6B3",
                    "on-secondary-container": "#4a3a2f",
                    "tertiary-container": "#7a5a45",
                    "error-container": "#ffdad6",
                    "background": "#fffaf7",
                    "on-primary": "#ffffff",
                    "secondary-fixed": "#FFF1E0"
            },

            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "spacing": {
                    "margin-sm": "16px",
                    "margin-lg": "64px",
                    "base": "8px",
                    "container-max": "1200px",
                    "margin-md": "32px",
                    "gutter": "24px"
            },
            "fontFamily": {
                    "technical-sm": [
                            "JetBrains Mono"
                    ],
                    "label-caps": [
                            "Inter"
                    ],
                    "headline-md": [
                            "Inter"
                    ],
                    "body-sm": [
                            "Inter"
                    ],
                    "technical-md": [
                            "JetBrains Mono"
                    ],
                    "body-md": [
                            "Inter"
                    ],
                    "headline-lg": [
                            "Inter"
                    ],
                    "headline-xl": [
                            "Inter"
                    ],
                    "body-lg": [
                            "Inter"
                    ]
            },
            "fontSize": {
                    "technical-sm": [
                            "12px",
                            {
                                    "lineHeight": "16px",
                                    "fontWeight": "400"
                            }
                    ],
                    "label-caps": [
                            "12px",
                            {
                                    "lineHeight": "16px",
                                    "letterSpacing": "0.05em",
                                    "fontWeight": "700"
                            }
                    ],
                    "headline-md": [
                            "24px",
                            {
                                    "lineHeight": "32px",
                                    "fontWeight": "600"
                            }
                    ],
                    "body-sm": [
                            "14px",
                            {
                                    "lineHeight": "20px",
                                    "fontWeight": "400"
                            }
                    ],
                    "technical-md": [
                            "14px",
                            {
                                    "lineHeight": "20px",
                                    "fontWeight": "500"
                            }
                    ],
                    "body-md": [
                            "16px",
                            {
                                    "lineHeight": "24px",
                                    "fontWeight": "400"
                            }
                    ],
                    "headline-lg": [
                            "32px",
                            {
                                    "lineHeight": "40px",
                                    "letterSpacing": "-0.01em",
                                    "fontWeight": "600"
                            }
                    ],
                    "headline-xl": [
                            "48px",
                            {
                                    "lineHeight": "56px",
                                    "letterSpacing": "-0.02em",
                                    "fontWeight": "700"
                            }
                    ],
                    "body-lg": [
                            "18px",
                            {
                                    "lineHeight": "28px",
                                    "fontWeight": "400"
                            }
                    ]
            }
          },
        },
      }
    </script>
</head>
<body class="bg-background text-on-surface font-body-md antialiased flex flex-col min-h-screen">
<!-- TopNavBar Component -->
<nav class="bg-surface-container-lowest dark:bg-inverse-surface shadow-sm dark:shadow-none fixed top-0 left-0 w-full z-50 flex items-center justify-between px-margin-md h-20 mx-auto">
<div class="flex items-center gap-margin-md">
<a href="/" class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/pinakaa_logo.jpg" alt="Pinakaa Logo" class="h-14 w-auto object-contain"/>
</a>
<div class="hidden md:flex items-center gap-margin-sm h-full">
<% if (role === 'admin') { %>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/download">Containers</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/documentation">Documentation</a>
<a class="text-body-md text-on-surface-variant dark:text-surface-variant px-3 py-2 hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200 h-full flex items-center" href="/contact">Contact</a>
<a class="text-body-md text-primary dark:text-inverse-primary border-b-2 border-primary dark:border-inverse-primary font-bold pb-1 h-full flex items-center" href="/admin">Support</a>
<% } %>
</div>
</div>
<div class="flex items-center gap-margin-sm">
<!-- Search Bar placeholder for "on_right" -->
<div class="hidden lg:flex items-center bg-surface-container border border-outline-variant rounded px-3 py-1.5 focus-within:border-primary transition-colors">
<span class="material-symbols-outlined text-on-surface-variant mr-2" style="font-size: 18px;">search</span>
<input class="bg-transparent border-none focus:ring-0 text-body-sm font-body-sm p-0 w-48 placeholder-on-surface-variant" placeholder="Search..." type="text"/>
</div>
<div class="flex items-center gap-3">
<button class="text-on-surface-variant hover:text-primary transition-colors mr-2" title="<%= username ? username : 'Guest' %>">
<span class="material-symbols-outlined">account_circle</span>
</button>
<% if (username) { %>
<a class="bg-white text-primary border border-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container hover:text-on-primary transition-colors ml-2 hidden sm:block" href="/change-password" style="text-decoration: none;">
                    Change Password
                </a>
<a class="bg-primary text-on-primary px-4 py-2 rounded text-body-sm font-semibold hover:bg-primary-container transition-colors ml-2 hidden sm:block" href="/logout" style="text-decoration: none;">
                    Logout
                </a>
<% } %>

<div class="flex items-center gap-margin-md">
<a class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/nsm_logo.png" alt="NSM Logo" class="h-14 w-auto object-contain" style="height: 70px;"/>
</a>
</div>
<div class="flex items-center gap-margin-md">
<a class="flex items-center hover:opacity-80 transition-opacity" style="text-decoration: none;">
    <img src="/assets/cdac_logo_blue.png" alt="C-DAC Logo" class="h-14 w-auto object-contain"/>
</a>
</div>

</div>
</div>
</nav>
<!-- Main Content Canvas -->
<main class="flex-grow pt-[80px] pb-margin-lg px-margin-sm md:px-margin-md max-w-container-max mx-auto w-full">
<div class="mb-margin-md">
<h1 class="font-headline-lg text-headline-lg text-on-surface mb-base">User Management</h1>
<p class="font-body-md text-body-md text-on-surface-variant">Administer secure access and review active authorizations.</p>
</div>
<% if (message) { %>
<div class="mb-margin-md rounded-DEFAULT border border-primary-container bg-primary-fixed p-4 text-primary">
    <p class="font-body-sm"><%= message %></p>
</div>
<% } %>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
<!-- Authorized Users Table Panel -->
<div class="lg:col-span-12 flex flex-col gap-margin-md">
<div class="bg-surface-container-lowest border border-outline-variant shadow-[0px_4px_20px_rgba(15,23,42,0.05)] rounded-DEFAULT p-margin-sm flex flex-col h-full">
<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-margin-sm gap-margin-sm">
<h2 class="font-headline-md text-headline-md text-on-surface flex items-center gap-base">
<span class="material-symbols-outlined text-secondary">hourglass_top</span>
                        Pending Login Requests
                    </h2>
</div>
<div class="overflow-x-auto rounded-DEFAULT border border-outline-variant bg-surface">
<table class="w-full text-left border-collapse">
<thead>
<tr class="bg-surface-container-low border-b border-outline-variant">
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Name</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Email</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Role</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Purpose</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Organization</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Architecture</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant text-right">Actions</th>
</tr>
</thead>
<tbody class="font-technical-sm text-technical-sm text-on-surface divide-y divide-outline-variant">
<% if (pendingRequests && pendingRequests.length) { %>
    <% pendingRequests.forEach(function(request) { %>
    <tr class="hover:bg-surface-container-lowest transition-colors">
        <td class="py-3 px-4"><%= request.name || request.username %></td>
        <td class="py-3 px-4"><%= request.email %></td>
        <td class="py-3 px-4"><%= request.role %></td>
        <td class="py-3 px-4"><%= request.purpose %></td>
        <td class="py-3 px-4"><%= request.organization || 'N/A' %></td>
        <td class="py-3 px-4"><%= request.target_device %></td>
        <td class="py-3 px-4 text-right">
            <div class="flex flex-col gap-2 items-end">
                <form method="POST" action="/admin/request/approve" class="inline">
                    <input type="hidden" name="id" value="<%= request.id %>" />
                    <button type="submit" class="rounded-full bg-primary px-4 py-2 text-on-primary font-semibold hover:bg-primary-container transition-colors">Approve</button>
                </form>
                <form method="POST" action="/admin/request/reject" class="inline flex flex-col gap-2 w-full max-w-sm">
                    <input type="hidden" name="id" value="<%= request.id %>" />
                    <input name="rejection_reason" type="text" placeholder="Rejection reason" class="w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-sm text-on-surface focus:border-error focus:outline-none" />
                    <button type="submit" class="rounded-full border border-error px-4 py-2 text-error font-semibold hover:bg-error-container hover:text-on-error transition-colors">Reject</button>
                </form>
            </div>
        </td>
    </tr>
    <% }); %>
<% } else { %>
    <tr>
        <td class="py-6 px-4 text-center text-body-sm text-on-surface-variant" colspan="7">No pending login requests.</td>
    </tr>
<% } %>
</tbody>
</table>
</div>
</div>
<div class="bg-surface-container-lowest border border-outline-variant shadow-[0px_4px_20px_rgba(15,23,42,0.05)] rounded-DEFAULT p-margin-sm flex flex-col h-full">
<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-margin-sm gap-margin-sm">
<h2 class="font-headline-md text-headline-md text-on-surface flex items-center gap-base">
<span class="material-symbols-outlined text-secondary">group</span>
                        Active Authorizations
                    </h2>
<div class="relative w-full sm:w-auto">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">search</span>
<input class="w-full sm:w-64 pl-10 pr-3 py-1.5 bg-surface-container-low border border-outline-variant rounded-DEFAULT focus:border-primary focus:ring-1 focus:ring-primary font-body-sm text-body-sm text-on-surface transition-colors" placeholder="Search logs..." type="text"/>
</div>
</div>
<div class="overflow-x-auto flex-grow rounded-DEFAULT border border-outline-variant bg-surface">
<table class="w-full text-left border-collapse">
<thead>
<tr class="bg-surface-container-low border-b border-outline-variant">
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">User Identifier</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Purpose</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Organization</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Architecture</th><th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Container Access</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Status</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant text-right">Actions</th>
</tr>
</thead>
<tbody class="font-technical-sm text-technical-sm text-on-surface divide-y divide-outline-variant">
    <% users.forEach(function(user) { %>
    <tr class="hover:bg-surface-container-lowest transition-colors">
        <td class="py-3 px-4">
            <div class="flex flex-col">
                <span class="font-technical-md text-technical-md text-primary"><%= user.username %></span>
                <span class="text-on-surface-variant"><%= user.email %></span>
            </div>
        </td>
        <td class="py-3 px-4 font-body-sm text-body-sm"><%= user.purpose %></td>
        <td class="py-3 px-4 font-body-sm text-body-sm"><%= user.organization || 'N/A' %></td>
        <td class="py-3 px-4"><%= user.target_device %></td>
        <td class="py-3 px-4"><%= user.container_access %></td>
        <td class="py-3 px-4">Active</td>
        <td class="py-3 px-4 text-right">
            <form method="POST" action="/admin/user/delete" class="inline">
                <input type="hidden" name="id" value="<%= user.id %>" />
                <button type="submit" class="text-error hover:text-on-error-container font-semibold">Delete</button>
            </form>
        </td>
    </tr>
    <% }); %>
</tbody>
</table>
</div>
<div class="mt-base flex justify-between items-center text-on-surface-variant font-technical-sm text-technical-sm">
<span>Showing 3 of 142 authorized entities</span>
<div class="flex gap-2">
<button class="p-1 hover:bg-surface-container-high rounded-DEFAULT transition-colors"><span class="material-symbols-outlined text-[18px]">chevron_left</span></button>
<button class="p-1 hover:bg-surface-container-high rounded-DEFAULT transition-colors"><span class="material-symbols-outlined text-[18px]">chevron_right</span></button>
</div>
</div>
</div>
</div>
</main>
<footer class="w-full bg-surface-container-low border-t border-outline-variant mt-auto">
<div class="w-full py-margin-md px-margin-md flex flex-col md:flex-row justify-between items-center gap-base mx-auto">
<div class="flex flex-col gap-2 items-center md:items-start text-center md:text-left">
<!-- Fallback to JSON standard structure for Brand Logo if needed, though mostly standard copyright -->
<p class="font-body-sm text-body-sm text-secondary">© 2026 System Software Development Group, NSM-STF, C-DAC, Bengaluru. All rights reserved</p>
</div>
<nav class="flex flex-wrap justify-center gap-margin-sm">
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Terms of Service</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Privacy Policy</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Security Audit</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">API Reference</a>
<a class="font-technical-sm text-technical-sm text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Status</a>
</nav>
</div>
</footer>
</body></html>