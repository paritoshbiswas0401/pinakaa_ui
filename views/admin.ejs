                            }
                    ],
                    "body-lg": [
                            "18px",
                            {
                                    "lineHeight": "28px",
                                    "fontWeight": "400"
                            }
                    ]
            }
          },
        },
      }
    </script>
</head>
<body class="bg-background text-on-surface font-body-md antialiased flex flex-col min-h-screen">
<!-- TopNavBar (Shared Component) -->
<header class="fixed top-0 left-0 w-full z-50 flex items-center justify-between px-margin-md h-16 mx-auto bg-surface-container-lowest dark:bg-inverse-surface border-b border-outline-variant dark:border-outline shadow-sm dark:shadow-none transition-all duration-150">
<div class="flex items-center gap-margin-md">
<a class="font-headline-md text-headline-md font-bold text-primary dark:text-inverse-primary tracking-tight hover:opacity-80 transition-opacity" href="/">Singularity Hub</a>
<nav class="hidden md:flex gap-margin-sm">
<a class="text-on-surface-variant dark:text-surface-variant font-medium hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200" href="/download">Containers</a>
<a class="text-on-surface-variant dark:text-surface-variant font-medium hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200" href="#">Documentation</a>
<a class="text-primary dark:text-inverse-primary border-b-2 border-primary dark:border-inverse-primary font-bold pb-1" href="#">Support</a>
<a class="text-on-surface-variant dark:text-surface-variant font-medium hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200" href="/contact" title="Request container access: Name, Email, Purpose, Target Device/Architecture, Organization">Contact</a>
</nav>
</div>
<div class="flex items-center gap-margin-sm">
<a class="text-primary dark:text-inverse-primary font-medium hover:text-primary-container dark:hover:text-primary-fixed-dim transition-colors duration-200" href="/logout" style="text-decoration: none;">
                    Logout
                </a>
<div class="flex gap-base text-primary dark:text-inverse-primary">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;" title="<%= username ? username : 'Guest' %>">account_circle</span>
</div>
</div>
</header>
<!-- Main Content Canvas -->
<main class="flex-grow pt-[80px] pb-margin-lg px-margin-sm md:px-margin-md max-w-container-max mx-auto w-full">
<div class="mb-margin-md">
<h1 class="font-headline-lg text-headline-lg text-on-surface mb-base">User Management</h1>
<p class="font-body-md text-body-md text-on-surface-variant">Administer secure access and review active authorizations.</p>
</div>
<% if (message) { %>
<div class="mb-margin-md rounded-DEFAULT border border-primary-container bg-primary-fixed p-4 text-primary">
    <p class="font-body-sm"><%= message %></p>
</div>
<% } %>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
<!-- Authorized Users Table Panel -->
<div class="lg:col-span-12 flex flex-col gap-margin-md">
<div class="bg-surface-container-lowest border border-outline-variant shadow-[0px_4px_20px_rgba(15,23,42,0.05)] rounded-DEFAULT p-margin-sm flex flex-col h-full">
<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-margin-sm gap-margin-sm">
<h2 class="font-headline-md text-headline-md text-on-surface flex items-center gap-base">
<span class="material-symbols-outlined text-secondary">hourglass_top</span>
                        Pending Login Requests
                    </h2>
</div>
<div class="overflow-x-auto rounded-DEFAULT border border-outline-variant bg-surface">
<table class="w-full text-left border-collapse">
<thead>
<tr class="bg-surface-container-low border-b border-outline-variant">
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Name</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Email</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Role</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Purpose</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Organization</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Architecture</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant text-right">Actions</th>
</tr>
</thead>
<tbody class="font-technical-sm text-technical-sm text-on-surface divide-y divide-outline-variant">
<% if (pendingRequests && pendingRequests.length) { %>
    <% pendingRequests.forEach(function(request) { %>
    <tr class="hover:bg-surface-container-lowest transition-colors">
        <td class="py-3 px-4"><%= request.name || request.username %></td>
        <td class="py-3 px-4"><%= request.email %></td>
        <td class="py-3 px-4"><%= request.role %></td>
        <td class="py-3 px-4"><%= request.purpose %></td>
        <td class="py-3 px-4"><%= request.organization || 'N/A' %></td>
        <td class="py-3 px-4"><%= request.target_device %></td>
        <td class="py-3 px-4 text-right flex gap-2 justify-end">
            <form method="POST" action="/admin/request/approve" class="inline">
                <input type="hidden" name="id" value="<%= request.id %>" />
                <button type="submit" class="rounded-full bg-primary px-4 py-2 text-on-primary font-semibold hover:bg-primary-container transition-colors">Approve</button>
            </form>
            <form method="POST" action="/admin/request/reject" class="inline">
                <input type="hidden" name="id" value="<%= request.id %>" />
                <button type="submit" class="rounded-full border border-error px-4 py-2 text-error font-semibold hover:bg-error-container hover:text-on-error transition-colors">Reject</button>
            </form>
        </td>
    </tr>
    <% }); %>
<% } else { %>
    <tr>
        <td class="py-6 px-4 text-center text-body-sm text-on-surface-variant" colspan="7">No pending login requests.</td>
    </tr>
<% } %>
</tbody>
</table>
</div>
</div>
<div class="bg-surface-container-lowest border border-outline-variant shadow-[0px_4px_20px_rgba(15,23,42,0.05)] rounded-DEFAULT p-margin-sm flex flex-col h-full">
<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-margin-sm gap-margin-sm">
<h2 class="font-headline-md text-headline-md text-on-surface flex items-center gap-base">
<span class="material-symbols-outlined text-secondary">group</span>
                        Active Authorizations
                    </h2>
<div class="relative w-full sm:w-auto">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">search</span>
<input class="w-full sm:w-64 pl-10 pr-3 py-1.5 bg-surface-container-low border border-outline-variant rounded-DEFAULT focus:border-primary focus:ring-1 focus:ring-primary font-body-sm text-body-sm text-on-surface transition-colors" placeholder="Search logs..." type="text"/>
</div>
</div>
<div class="overflow-x-auto flex-grow rounded-DEFAULT border border-outline-variant bg-surface">
<table class="w-full text-left border-collapse">
<thead>
<tr class="bg-surface-container-low border-b border-outline-variant">
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">User Identifier</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Purpose</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Organization</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Architecture</th><th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Container Access</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant">Status</th>
<th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant text-right">Actions</th>
</tr>
</thead>
<tbody class="font-technical-sm text-technical-sm text-on-surface divide-y divide-outline-variant">
    <% users.forEach(function(user) { %>
    <tr class="hover:bg-surface-container-lowest transition-colors">
        <td class="py-3 px-4">
            <div class="flex flex-col">
                <span class="font-technical-md text-technical-md text-primary"><%= user.username %></span>
                <span class="text-on-surface-variant"><%= user.email %></span>
            </div>
        </td>
        <td class="py-3 px-4 font-body-sm text-body-sm"><%= user.purpose %></td>
        <td class="py-3 px-4 font-body-sm text-body-sm"><%= user.organization || 'N/A' %></td>
        <td class="py-3 px-4"><%= user.target_device %></td>
        <td class="py-3 px-4"><%= user.container_access %></td>
        <td class="py-3 px-4">Active</td>
        <td class="py-3 px-4 text-right">
            <form method="POST" action="/admin/user/delete" class="inline">
                <input type="hidden" name="id" value="<%= user.id %>" />
                <button type="submit" class="text-error hover:text-on-error-container font-semibold">Delete</button>
            </form>
        </td>
    </tr>
    <% }); %>
</tbody>
</table>
</div>
<div class="mt-base flex justify-between items-center text-on-surface-variant font-technical-sm text-technical-sm">
<span>Showing 3 of 142 authorized entities</span>
<div class="flex gap-2">
<button class="p-1 hover:bg-surface-container-high rounded-DEFAULT transition-colors"><span class="material-symbols-outlined text-[18px]">chevron_left</span></button>
<button class="p-1 hover:bg-surface-container-high rounded-DEFAULT transition-colors"><span class="material-symbols-outlined text-[18px]">chevron_right</span></button>
</div>
</div>
</div>
</div>
</main>
<footer class="w-full py-margin-md px-margin-md flex flex-col md:flex-row justify-between items-center gap-base max-w-container-max mx-auto bg-surface-container-low dark:bg-inverse-surface border-t border-outline-variant dark:border-outline mt-auto">
<div class="flex flex-col items-center md:items-start gap-1">
<span class="font-headline-sm text-headline-sm font-semibold text-on-surface dark:text-inverse-on-surface">Singularity Hub</span>
<p class="font-body-sm text-body-sm text-secondary dark:text-secondary-fixed">© 2024 HPC Systems. All rights reserved. Secure Singularity Container Distribution.</p>
</div>
<nav class="flex flex-wrap justify-center gap-margin-sm font-technical-sm text-technical-sm">
<a class="text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Terms of Service</a>
<a class="text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Privacy Policy</a>
<a class="text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Security Audit</a>
<a class="text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">API Reference</a>
<a class="text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200" href="#">Status</a>
</nav>
</footer>
</body></html>