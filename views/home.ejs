<section class="grid grid-cols-1 md:grid-cols-12 gap-gutter items-center min-h-[614px]">
<!-- Left Content: Typography & CTA -->
<div class="md:col-span-4 flex flex-col gap-margin-sm relative">
<!-- Abstract Technical Image Area -->
<div class="w-full min-h-[420px] md:min-h-[520px] bg-surface-container-low border border-outline-variant rounded-lg overflow-hidden relative shadow-ambient">
<!-- Using a placeholder image with the mandated highly detailed prompt in data-alt -->
<img alt="Pinakaa stack" class="object-cover w-full h-full"
    data-alt="PINAKAA STACK IMAGE"
    src="/assets/pinakaa_stack.jpg"
    style="height: 500px; width: 600px; object-fit: fill; background-color: #FFF8F2;"/>
</div>
<!-- Prominent 'Total Downloads' Badge anchored to the visual -->
<div class="absolute -bottom-6 -left-4 bg-surface-container-lowest border border-outline-variant rounded p-margin-sm shadow-ambient flex flex-col gap-1 z-20">
<span class="font-label-caps text-label-caps text-secondary flex items-center gap-1">
<span class="material-symbols-outlined text-[16px]">bar_chart</span>
                        Total Downloads
                    </span>
<span class="font-technical-md text-technical-md text-on-surface text-3xl">
                        <%= downloads %><span class="text-primary animate-pulse">_</span>
</span>
</div>
</div>
<!-- Right Content: Technical Visual & Stats Anchor -->
<div class="md:col-span-8 flex flex-col items-start gap-margin-md z-10 pr-4 md:pr-12">
<div class="flex flex-col gap-base">
<div class="inline-flex items-center gap-2 bg-surface-container-low border border-outline-variant px-3 py-1 rounded text-secondary font-label-caps text-label-caps">
<span class="material-symbols-outlined text-sm">verified</span>
                        STABLE BUILD v1.0.0
                    </div>
<h1 class="font-headline-xl text-headline-xl text-on-surface">PINAKAA Studio</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant mt-base">
                        A comprehensive HPC software suite for scalable, sustainable and performance-driven computing. It is designed to provide end-to-end support for deploying and managing Rudra III–based HPC-AI servers and Supercomputers. PINAKAA is
an Exascale-ready modular suite that empowers next-generation HPC and AI workloads on India’s indigenous Rudra III
platforms. </p>
</div>
<div class="flex flex-wrap items-center gap-margin-sm mt-base">
<!-- Primary CTA -->
<a class="bg-primary text-on-primary font-label-caps text-label-caps px-margin-md py-3 rounded shadow-sm hover:bg-primary-container transition-colors flex items-center gap-2" href="/login" style="text-decoration: none;">
<span class="material-symbols-outlined">download</span>
                        Sign In to Download
                    </a>
<!-- Secondary Action -->
<a class="bg-transparent text-secondary border border-outline font-label-caps text-label-caps px-margin-md py-3 rounded hover:bg-surface-container-low transition-colors flex items-center gap-2" href="/documentation" style="text-decoration: none;">
<span class="material-symbols-outlined">description</span>
                        Documentation
                    </a>
</div>
<!-- Integrity Badge / Checksum snippet -->
<div class="bg-surface-container-lowest border border-outline-variant rounded p-3 mt-margin-sm flex items-center gap-margin-sm w-full max-w-md shadow-ambient">
<span class="material-symbols-outlined text-primary">lock</span>
<div class="flex flex-col w-full overflow-hidden">
<span class="font-label-caps text-label-caps text-on-surface-variant">SHA-256 VERIFIED</span>
<span class="font-technical-sm text-technical-sm text-secondary truncate">e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855</span>
</div>
</div>
</div>

</section>
<hr class="border-outline-variant/50 w-full"/>
<!-- Features Section (Technical Grid) -->
<section class="flex flex-col gap-margin-md pb-margin-lg">
<div class="flex flex-col gap-base items-center text-center max-w-2xl mx-auto">
<h2 class="font-headline-lg text-headline-lg text-on-surface">Core Capabilities</h2>
<p class="font-body-md text-body-md text-on-surface-variant">Built on a foundation of structural integrity and technical minimalism, PINAKAA provides the essential tools for modern research workflows.</p>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-gutter mt-margin-sm">
<!-- Feature 1 -->
<div class="bg-surface-container-lowest border border-outline-variant rounded p-margin-md shadow-ambient hover:shadow-md transition-all flex flex-col gap-margin-sm group">
<div class="w-12 h-12 bg-surface-container-low rounded flex items-center justify-center border border-outline-variant group-hover:bg-primary-fixed group-hover:border-primary-fixed-dim transition-colors">
<span class="material-symbols-outlined text-primary text-2xl">speed</span>
</div>
<div class="flex flex-col gap-2">
<h3 class="font-headline-md text-headline-md text-on-surface text-[20px]">High Performance</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Native execution speeds with negligible overhead. Direct access to host hardware including GPUs and specialized interconnects without compromise.</p>
</div>
</div>
<!-- Feature 2 -->
<div class="bg-surface-container-lowest border border-outline-variant rounded p-margin-md shadow-ambient hover:shadow-md transition-all flex flex-col gap-margin-sm group">
<div class="w-12 h-12 bg-surface-container-low rounded flex items-center justify-center border border-outline-variant group-hover:bg-primary-fixed group-hover:border-primary-fixed-dim transition-colors">
<span class="material-symbols-outlined text-primary text-2xl">autorenew</span>
</div>
<div class="flex flex-col gap-2">
<h3 class="font-headline-md text-headline-md text-on-surface text-[20px]">Reproducible</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Single-file container formats ensure environments are perfectly preserved. Move effortlessly from laptop development to cluster deployment.</p>
</div>
</div>
<!-- Feature 3 -->
<div class="bg-surface-container-lowest border border-outline-variant rounded p-margin-md shadow-ambient hover:shadow-md transition-all flex flex-col gap-margin-sm group">
<div class="w-12 h-12 bg-surface-container-low rounded flex items-center justify-center border border-outline-variant group-hover:bg-primary-fixed group-hover:border-primary-fixed-dim transition-colors">
<span class="material-symbols-outlined text-primary text-2xl">security</span>
</div>
<div class="flex flex-col gap-2">
<h3 class="font-headline-md text-headline-md text-on-surface text-[20px]">Secure by Design</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Untrusted users can run untrusted containers safely. Built-in cryptographic signatures and immutable deployment mechanisms.</p>
</div>
</div>
</div>
</section>
